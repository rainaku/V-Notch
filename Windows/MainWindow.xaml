        <SolidColorBrush x:Key="MusicVisualizerBrush" Color="White"/>

        <LinearGradientBrush x:Key="TrackTitleGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="White" Offset="0"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>

        <LinearGradientBrush x:Key="TrackTitleNextGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="White" Offset="0"/>
            <GradientStop Color="White" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="TrayMenuItemText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource MainSystemFont}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="TrayMenuIcon" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#D8D8D8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Width" Value="22"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
        </Style>

        <Style x:Key="TrayContextMenuStyle" TargetType="ContextMenu">
            <Setter Property="Width" Value="170"/>
            <Setter Property="Background" Value="#1F1F1F"/>
            <Setter Property="BorderBrush" Value="#3B3B3B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="OverridesDefaultStyle" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TrayMenuItemStyle" TargetType="MenuItem">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource MainSystemFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="20,0,16,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Stretch"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2B2B2B"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TraySeparatorStyle" TargetType="Separator">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="#404040"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="1" Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid RenderOptions.ClearTypeHint="Enabled">

        <tb:TaskbarIcon x:Name="TrayIcon"
                        ToolTipText="V-Notch"
                        MenuActivation="RightClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu Style="{StaticResource TrayContextMenuStyle}"
                             Opened="TrayContextMenu_Opened"
                             Closed="TrayContextMenu_Closed">
                    <MenuItem x:Name="MenuToggle" Style="{StaticResource TrayMenuItemStyle}" Click="ToggleNotch_Click">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8A7;" Style="{StaticResource TrayMenuIcon}" Margin="0,0,10,0"/>
                                <TextBlock Text="Hide Notch" Style="{StaticResource TrayMenuItemText}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <MenuItem Style="{StaticResource TrayMenuItemStyle}" Click="ResetPosition_Click">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE777;" Style="{StaticResource TrayMenuIcon}" Margin="0,0,10,0"/>
                                <TextBlock Text="Reset position" Style="{StaticResource TrayMenuItemText}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator Style="{StaticResource TraySeparatorStyle}"/>
                    <MenuItem Style="{StaticResource TrayMenuItemStyle}" Click="OpenSettings_Click">
                        <MenuItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" Style="{StaticResource TrayMenuIcon}" Margin="0,0,10,0"/>
                                <TextBlock Text="Notch settings" Style="{StaticResource TrayMenuItemText}"/>
                            </StackPanel>
                        </MenuItem.Header>
                    </MenuItem>
                    <Separator Style="{StaticResource TraySeparatorStyle}"/>
                    <MenuItem Style="{StaticResource TrayMenuItemStyle}" Click="Exit_Click">
                        <MenuItem.Header>
                            <TextBlock Text="Exit" Style="{StaticResource TrayMenuItemText}" HorizontalAlignment="Center"/>
                        </MenuItem.Header>
                    </MenuItem>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <Grid x:Name="NotchContainer" RenderOptions.ClearTypeHint="Enabled">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="NotchContainerTranslate" Y="0"/>
            </Grid.RenderTransform>

            <Grid x:Name="NotchShadowWrapper" 
                  HorizontalAlignment="Center" 
                  VerticalAlignment="Top"
                  Margin="0,-0.5,0,0"
                  RenderTransformOrigin="0.5,0"
                  Effect="{StaticResource NotchShadow}">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="NotchShadowScale" ScaleX="1" ScaleY="1"/>
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0" 
                      Data="M 0,0 L 10,0 L 10,10 Q 10,0 0,0 Z" 
                      Fill="Black" 
                      Width="11" Height="10" 
                      Margin="0,0,-1,0"
                      VerticalAlignment="Top"/>

                <Border x:Name="NotchBorderShadow"
                        Grid.Column="1"
                        Background="Black"
                        CornerRadius="{Binding CornerRadius, ElementName=NotchBorder}"
                        Width="{Binding Width, ElementName=NotchBorder}"
                        Height="{Binding Height, ElementName=NotchBorder}"/>

                <Path Grid.Column="2" 
                      Data="M 0,10 L 0,0 L 11,0 Q 1,0 1,10 Z" 
                      Fill="Black" 
                      Width="11" Height="10" 
                      Margin="-1,0,0,0"
                      VerticalAlignment="Top"/>
            </Grid>

