                                      Fill="Transparent"
                                      Visibility="Collapsed">
                                    <Path.Stroke>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FFFFFF" Offset="0"/>
                                            <GradientStop Color="#A0A0A0" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Path.Stroke>
                                </Path>
                            </Canvas>
                        </Viewbox>
                    </Grid>

                    <!-- Privacy Indicator Dots (iOS-style mic/camera in-use) -->
                    <StackPanel x:Name="PrivacyIndicatorPanel"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,11.2,27,0"
                                Opacity="0"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                        <!-- Single unified dot — orange for mic, green for cam, gradient transition when both active -->
                        <Border x:Name="PrivacyDot"
                                Width="7" Height="7"
                                CornerRadius="3.5"
                                Visibility="Collapsed"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.Background>
                                <SolidColorBrush x:Name="PrivacyDotBrush" Color="#50C878"/>
                            </Border.Background>
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="PrivacyDotScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                        </Border>
                    </StackPanel>

                    <!-- Bluetooth Connected Notification -->
                    <Grid x:Name="BluetoothNotification"
                          Opacity="0"
                          Visibility="Collapsed"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Margin="10,0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="BluetoothNotificationTranslate" Y="0"/>
                        </Grid.RenderTransform>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,6">
                            <Viewbox Width="14" Height="14" Margin="0,1,6,0"
                                     VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Viewbox.RenderTransform>
                                    <ScaleTransform x:Name="BluetoothIconScale" ScaleX="1" ScaleY="1"/>
                                </Viewbox.RenderTransform>
                                <Canvas Width="24" Height="24">
                                    <Path x:Name="BluetoothIcon"
                                          Data="M17.71,7.71L12,2h-1v7.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L11,14.41V22h1l5.71-5.71L13.41,12L17.71,7.71z M13,5.83l1.88,1.88L13,9.59V5.83z M14.88,16.29L13,18.17v-3.76L14.88,16.29z"
                                          Fill="#0A84FF"/>
                                </Canvas>
                            </Viewbox>
                            <Border x:Name="BluetoothStatusIndicator"
                                    Width="5" Height="5"
                                    CornerRadius="2.5"
                                    Background="#30D158"
                                    Margin="0,1,5,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock x:Name="BluetoothDeviceName"
                                       Text=""
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       FontFamily="{StaticResource MainSystemFont}"
                                       VerticalAlignment="Center"
                                       Margin="0,2,0,0"
                                       MaxWidth="140"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="BluetoothStatusText"
                                       Text=""
                                       Foreground="#80FFFFFF"
                                       FontSize="11"
                                       FontWeight="Normal"
                                       FontFamily="{StaticResource MainSystemFont}"
                                       VerticalAlignment="Center"
                                       Margin="5,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bluetooth Disconnected Notification -->
                    <Grid x:Name="BluetoothDisconnectNotification"
                          Opacity="0"
                          Visibility="Collapsed"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Margin="10,0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="BluetoothDisconnectNotificationTranslate" Y="0"/>
                        </Grid.RenderTransform>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,6">
                            <Viewbox Width="14" Height="14" Margin="0,1,6,0"
                                     VerticalAlignment="Center"
                                     RenderTransformOrigin="0.5,0.5">
                                <Viewbox.RenderTransform>
                                    <ScaleTransform x:Name="BluetoothDisconnectIconScale" ScaleX="1" ScaleY="1"/>
                                </Viewbox.RenderTransform>
                                <Canvas Width="24" Height="24">
                                    <Path x:Name="BluetoothDisconnectIcon"
                                          Data="M17.71,7.71L12,2h-1v7.59L6.41,5L5,6.41L10.59,12L5,17.59L6.41,19L11,14.41V22h1l5.71-5.71L13.41,12L17.71,7.71z M13,5.83l1.88,1.88L13,9.59V5.83z M14.88,16.29L13,18.17v-3.76L14.88,16.29z"
                                          Fill="#0A84FF"/>
                                </Canvas>
                            </Viewbox>
                            <Border x:Name="BluetoothDisconnectStatusIndicator"
                                    Width="5" Height="5"
                                    CornerRadius="2.5"
                                    Background="#FF453A"
                                    Margin="0,4,5,0"
                                    VerticalAlignment="Center"/>
                            <TextBlock x:Name="BluetoothDisconnectDeviceName"
                                       Text=""
                                       Foreground="White"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       FontFamily="{StaticResource MainSystemFont}"
                                       VerticalAlignment="Center"
                                       Margin="0,2,0,0"
                                       MaxWidth="140"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="BluetoothDisconnectStatusText"
                                       Text=""
                                       Foreground="#80FFFFFF"
                                       FontSize="11"
                                       FontWeight="Normal"
                                       FontFamily="{StaticResource MainSystemFont}"
                                       VerticalAlignment="Center"
                                       Margin="5,2,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Battery Charging Notification -->
                    <Grid x:Name="ChargingNotification"
                          Opacity="0"
                          Visibility="Collapsed"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Margin="14,0,10,0">
                        <Grid.RenderTransform>
                            <TranslateTransform x:Name="ChargingNotificationTranslate" Y="0"/>
                        </Grid.RenderTransform>
                        <Grid HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left: "Charging" text -->
                            <TextBlock x:Name="ChargingStatusText"
                                       Grid.Column="0"
                                       Text="Charging"
                                       Foreground="White"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       FontFamily="{StaticResource MainSystemFont}"
                                       TextOptions.TextFormattingMode="Ideal"
                                       TextOptions.TextRenderingMode="ClearType"
                                       TextOptions.TextHintingMode="Fixed"
                                       UseLayoutRounding="True"
                                       SnapsToDevicePixels="True"
                                       VerticalAlignment="Center"/>

                            <!-- Right: percentage + battery icon -->
                            <StackPanel Grid.Column="1"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="ChargingPercentText"
                                           Text="100%"
                                           Foreground="#30D158"
                                           FontSize="11.5"
                                           FontWeight="Bold"
                                           FontFamily="{StaticResource MainSystemFont}"
                                           TextOptions.TextFormattingMode="Ideal"
                                           TextOptions.TextRenderingMode="ClearType"
                                           TextOptions.TextHintingMode="Fixed"
                                           UseLayoutRounding="True"
                                           SnapsToDevicePixels="True"
                                           VerticalAlignment="Center"
                                           Margin="0,0,5,0"/>
                                <!-- Mini battery icon -->
                                <Grid Width="22" Height="12" VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <ScaleTransform x:Name="ChargingIconScale" ScaleX="1" ScaleY="1"/>
                                    </Grid.RenderTransform>
                                    <!-- Battery body -->
                                    <Border BorderBrush="#60FFFFFF" BorderThickness="1" CornerRadius="2.5"
                                            HorizontalAlignment="Left" Width="20" Height="10"
                                            VerticalAlignment="Center"/>
                                    <!-- Battery tip -->
                                    <Border Background="#60FFFFFF" Width="1.5" Height="5" CornerRadius="0,1,1,0"
                                            HorizontalAlignment="Right" VerticalAlignment="Center"
                                            Margin="0,0,-1,0"/>
                                    <!-- Battery fill -->
                                    <Border x:Name="ChargingBatteryFill"
                                            Background="#30D158" 
                                            CornerRadius="1.5"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Height="7" Width="17"
                                            Margin="1.5,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid x:Name="MusicCompactContent"
                          Opacity="0"
                          Visibility="Collapsed"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Top"
                          Margin="8,4"
                          RenderOptions.ClearTypeHint="Enabled">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="CompactThumbnailBorder"
                                Grid.Row="0"
                                Grid.Column="0" 
                                Width="22" Height="22" 
                                CornerRadius="6" 
                                Background="#1A1A1A"
                                BorderBrush="#333333"
                                BorderThickness="0.5"
                                ClipToBounds="True"
                                Cursor="Hand"
                                RenderTransformOrigin="0,0"
                                MouseLeftButtonDown="CompactThumbnailBorder_MouseLeftButtonDown"
                                MouseEnter="CompactThumbnailBorder_MouseEnter"
                                MouseLeave="CompactThumbnailBorder_MouseLeave">
                            <Border.Effect>
                                <BlurEffect x:Name="MusicCompactContentBlur" Radius="0" RenderingBias="Performance"/>
                            </Border.Effect>
                            <Border.RenderTransform>
                                <!-- Hover scale: scales from top-left (origin 0,0) so the thumbnail grows down+right within the notch as it expands. -->
                                <ScaleTransform x:Name="CompactThumbnailScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <!-- Two-layer crossfade host. Outgoing thumb is the base layer, incoming thumb fades in on top with a soft parallax zoom.... -->
                            <Grid Width="22" Height="22">
                                <Grid.Clip>
                                    <RectangleGeometry RadiusX="6" RadiusY="6" Rect="0,0,22,22"/>
                                </Grid.Clip>
                                <Image x:Name="CompactThumbnail"
                                       Stretch="UniformToFill"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform x:Name="CompactThumbnailOutScale" ScaleX="1" ScaleY="1"/>
                                    </Image.RenderTransform>
                                    <Image.Effect>
                                        <BlurEffect x:Name="CompactThumbnailOutBlur" Radius="0" RenderingBias="Performance"/>
                                    </Image.Effect>
                                </Image>
                                <Image x:Name="CompactThumbnailNext"
                                       Stretch="UniformToFill"
                                       Opacity="0"
                                       IsHitTestVisible="False"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform x:Name="CompactThumbnailNextScale" ScaleX="1" ScaleY="1"/>
                                    </Image.RenderTransform>
                                    <Image.Effect>
                                        <BlurEffect x:Name="CompactThumbnailNextBlur" Radius="0" RenderingBias="Performance"/>
                                    </Image.Effect>
                                </Image>
                            </Grid>
                        </Border>

                        <Grid x:Name="CompactHoverInfo"
                              Grid.Row="1"
                              Grid.Column="0"
                              Grid.ColumnSpan="3"
                              Opacity="0"
                              Visibility="Collapsed"
                              VerticalAlignment="Bottom"
                              Margin="-6,14,-6,8">
                            <Grid.OpacityMask>
                                <LinearGradientBrush x:Name="CompactMarqueeFadeBrush" StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="Black" Offset="0.02"/>
                                    <GradientStop Color="Black" Offset="0.98"/>
                                    <GradientStop Color="Transparent" Offset="1"/>
                                </LinearGradientBrush>
                            </Grid.OpacityMask>
                            <Canvas x:Name="CompactTitleScrollContainer" Height="18" HorizontalAlignment="Stretch" ClipToBounds="True" Margin="0,5,0,0">
                                <TextBlock x:Name="CompactTitleMarquee" 
                                           Text="Title" 
                                           Style="{StaticResource TitleText}" 
                                           FontSize="10.5"
                                           FontWeight="Bold"
                                           Foreground="#EEFFFFFF"
                                           TextOptions.TextFormattingMode="Ideal"
                                           VerticalAlignment="Center">
                                    <TextBlock.RenderTransform>
                                        <TranslateTransform x:Name="CompactTitleMarqueeTranslate" X="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Canvas>
                        </Grid>

                        <ctrl:MusicVisualizer x:Name="MusicViz" 
                                              Grid.Row="0" Grid.Column="2" 
                                              Width="20" Height="17"
                                              Margin="0,2.5,-4,0"
                                              VerticalAlignment="Top"
                                              ActiveBrush="{StaticResource MusicVisualizerBrush}">
                            <ctrl:MusicVisualizer.Effect>
                                <BlurEffect Radius="1.6" RenderingBias="Performance"/>
                            </ctrl:MusicVisualizer.Effect>
                        </ctrl:MusicVisualizer>

                        <!-- Clipboard copied checkmark (overlays MusicViz position) -->
                        <Canvas x:Name="ClipboardCheckIcon"
                                Grid.Row="0" Grid.Column="2"
                                Width="16" Height="16"
                                Margin="2,4,-2,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Opacity="0"
                                Visibility="Collapsed"
                                IsHitTestVisible="False"
                                RenderTransformOrigin="0.5,0.5">
                            <Canvas.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform x:Name="ClipboardCheckScale" ScaleX="0.5" ScaleY="0.5"/>
                                </TransformGroup>
                            </Canvas.RenderTransform>
                            <Path Data="M2.5,8.5 L6,12 L13.5,4.5"
                                  Stroke="White" StrokeThickness="2.2"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round"
                                  Fill="Transparent"/>
                        </Canvas>

                        <!-- Clipboard "Copied" text (between thumbnail and equalizer) -->
                        <TextBlock x:Name="ClipboardCopiedText"
                                   Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="Copied"
                                   Foreground="White"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   FontFamily="{StaticResource MainSystemFont}"
                                   TextOptions.TextFormattingMode="Ideal"
                                   TextOptions.TextRenderingMode="ClearType"
                                   TextOptions.TextHintingMode="Fixed"
                                   UseLayoutRounding="True"
                                   SnapsToDevicePixels="True"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Left"
                                   Margin="0,4,0,0"
                                   Opacity="0"
                                   Visibility="Collapsed"
                                   IsHitTestVisible="False"
                                   RenderTransformOrigin="0,0.5">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="ClipboardCopiedTranslate" X="-8"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>

                    </Grid>

                    <Grid x:Name="ExpandedContent" 
                          Opacity="0" 
                          Visibility="Collapsed"
                          Margin="8,2,8,0"
                          Background="{StaticResource NotchGradient}"
                          ClipToBounds="False"
                          RenderOptions.ClearTypeHint="Enabled">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.48*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="0.72*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Status Bar: Battery + Update + Settings (Overlay on top) -->
                        <Grid x:Name="StatusBar" Grid.Column="0" Grid.ColumnSpan="3" 
                              HorizontalAlignment="Right" VerticalAlignment="Top" 
                              Margin="0,0,5,0" Panel.ZIndex="100">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <!-- Battery Section -->
                            <Border x:Name="BatterySection" Grid.Column="0"
                                    Cursor="Hand"
                                    Background="Transparent"
                                    MouseLeftButtonDown="Battery_Click"
                                    MouseEnter="BatterySection_MouseEnter"
                                    MouseLeave="BatterySection_MouseLeave"
                                    RenderTransformOrigin="0.5,0.5"
                                    Opacity="0">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="BatterySectionScale" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="BatteryTranslate" Y="-4"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="BatteryPercent" 
                                               Text="100%" 
                                               Style="{StaticResource SubtitleText}"
                                               FontSize="12"
                                               Foreground="#CCFFFFFF"
                                               FontWeight="Bold"
                                               Margin="0,1.5,0,0"
                                               VerticalAlignment="Center"/>
                                    <Grid Margin="4.51,0,0,0">
                                        <!-- Battery Body -->
                                        <Border x:Name="BatteryIcon"
                                                Width="27.08" Height="14.44"
                                                BorderBrush="#666666"
                                                BorderThickness="1.36"
                                                CornerRadius="4.07"
                                                Panel.ZIndex="1">
                                            <Grid>
                                                <Border x:Name="BatteryFill"
                                                        Background="White"
                                                        CornerRadius="2.71"
                                                        HorizontalAlignment="Left"
                                                        Margin="1.36,1.08,0,1.08"
                                                        Width="22.8">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform x:Name="BatteryFillScale" ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        
                                        <!-- Battery Terminal -->
                                        <Border Width="2.71" Height="7.22"
                                                Background="#666666"
                                                CornerRadius="0,2.26,2.26,0"
                                                HorizontalAlignment="Right"
                                                Margin="0,0,-2.71,0"
                                                Panel.ZIndex="1"/>
                                        
                                        <!-- Lightning Bolt Icon (Charging Indicator) - Overlay on top -->
                                        <Viewbox x:Name="ChargingBolt" 
                                                 Width="13.3" Height="17.1"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Margin="1,0,0,0"
                                                 Opacity="0"
                                                 RenderTransformOrigin="0.5,0.5"
                                                 Panel.ZIndex="10">
                                            <Viewbox.RenderTransform>
                                                <ScaleTransform x:Name="ChargingBoltScale" ScaleX="0.95" ScaleY="0.95"/>
                                            </Viewbox.RenderTransform>
                                            <Grid>
                                                <!-- Black border: filled black shape scaled up slightly -->
                                                <Path Data="M 13 2 L 3 14 L 8 14 L 7 22 L 17 10 L 12 10 L 13 2 Z"
                                                      Fill="Black"
                                                      Stroke="Black"
                                                      StrokeThickness="5.5"
                                                      StrokeLineJoin="Round"
                                                      Stretch="Uniform"/>
                                                <!-- White fill on top -->
                                                <Path Data="M 13 2 L 3 14 L 8 14 L 7 22 L 17 10 L 12 10 L 13 2 Z"
                                                      Fill="White"
                                                      Stretch="Uniform"/>
                                            </Grid>
                                        </Viewbox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Update Notification Button with Breathing Effect -->
                            <Border x:Name="UpdateNotificationButton" Grid.Column="1"
                                    Width="20" Height="20"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Margin="7,0,0,0"
                                    ToolTipService.IsEnabled="False"
                                    MouseLeftButtonDown="UpdateNotification_Click"
                                    MouseEnter="UpdateNotification_MouseEnter"
                                    MouseLeave="UpdateNotification_MouseLeave"
                                    RenderTransformOrigin="0.5,0.5"
                                    Opacity="0"
                                    Visibility="Collapsed"
                                    IsHitTestVisible="True"
                                    Tag="1.0.0">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="UpdateNotificationScale" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="UpdateNotificationTranslate" Y="-4"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Viewbox Width="16" Height="16" Stretch="Uniform">
                                    <Canvas Width="512" Height="512">
                                        <!-- Update icon with breathing color animation -->
                                        <Path x:Name="UpdateIconPath"
                                              Data="M104.426,139.813l83.563,83.781c14.344-13.766,26.781-25.703,36.109-34.672l-84.297-84.5l-10.313-45.719 L54.27,12.985L33.629,33.642L12.988,54.282l45.719,75.219L104.426,139.813z M358.363,276.298L481.926,399.47c22.781,22.766,22.781,59.688,0,82.469c-22.781,22.766-59.688,22.766-82.469,0 L275.895,358.767L358.363,276.298z M459.957,203.407c42.547-38.609,49.656-82.484,40.141-119.484c-0.281-2.938-0.984-5.406-3.547-7.25 l-8.563-7.016c-1.484-1.391-3.484-2.063-5.484-1.875c-2.016,0.203-3.844,1.234-5.031,2.875l-49.25,64.031 c-1.375,1.891-3.594,2.969-5.922,2.891l-17.875,1.313c-1.531-0.047-3.016-0.594-4.219-1.563l-34.531-29.266 c-1.406-1.141-2.328-2.766-2.563-4.563l-2.141-16.188c-0.25-1.781,0.203-3.594,1.266-5.063l46.109-62.641 c2.094-2.875,1.688-6.859-0.906-9.281l-11.188-8.75c-2.188-2.031-4.672-1.75-8.063-1.094 c-31.844,6.281-86.219,37.125-100.016,79.75c-12.156,37.516-7.922,63.969-7.922,63.969c0,21.141-6.953,41.516-15.5,50.063 L24.504,424.923c-0.469,0.422-0.922,0.859-1.375,1.313c-19.844,19.844-19.813,52.047-0.641,71.219s51.859,19.672,71.703-0.172 c0.922-0.922,1.813-1.875,2.641-2.859l231.672-250.438C357.004,218.61,413.426,245.642,459.957,203.407z">
                                            <Path.Fill>
                                                <SolidColorBrush x:Name="UpdateIconBrush" Color="#30D158"/>
                                            </Path.Fill>
                                        </Path>
                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <!-- Settings Button -->
                            <Border x:Name="SettingsButton" Grid.Column="2"
                                    Width="24" Height="24"
                                    CornerRadius="12"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    Margin="7,0,0,0"
                                    MouseLeftButtonDown="Settings_Click"
                                    PreviewMouseRightButtonDown="SettingsButton_PreviewMouseRightButtonDown"
                                    MouseRightButtonDown="SettingsButton_PreviewMouseRightButtonDown"
                                    MouseEnter="SettingsButton_MouseEnter"
                                    MouseLeave="SettingsButton_MouseLeave"
                                    RenderTransformOrigin="0.5,0.5"
                                    Opacity="0"
                                    Visibility="Visible"
                                    IsHitTestVisible="True">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="SettingsScale" ScaleX="1" ScaleY="1"/>
                                        <RotateTransform x:Name="SettingsRotate" Angle="45"/>
                                        <TranslateTransform x:Name="SettingsTranslate" Y="-4"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Viewbox Width="16.2" Height="16.2" Stretch="Uniform"
                                         SnapsToDevicePixels="True"
                                         UseLayoutRounding="True">
                                    <Canvas Width="56" Height="56"
