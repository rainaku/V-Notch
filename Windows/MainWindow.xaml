                                                        Grid.Column="1"
                                                        Background="Transparent"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="PlayPauseButton_Click"
                                                        MouseEnter="MediaButton_MouseEnter"
                                                        MouseLeave="MediaButton_MouseLeave"
                                                        Width="32" Height="26"
                                                        Margin="0"
                                                        HorizontalAlignment="Center"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                    <Viewbox Width="12.8" Height="13">
                                                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <Canvas x:Name="PauseIcon" Width="46" Height="46" Visibility="Visible" RenderTransformOrigin="0.5,0.5">
                                                                <Canvas.RenderTransform>
                                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                </Canvas.RenderTransform>
                                                                <Path x:Name="PauseIconPath"
                                                                      Width="48"
                                                                      Height="45.812"
