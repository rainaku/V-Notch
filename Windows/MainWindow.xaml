                  HorizontalAlignment="Center" 
                  VerticalAlignment="Top"
                  RenderTransformOrigin="0.5,0"
                  Cursor="Hand"
                  MouseLeftButtonDown="NotchBorder_MouseLeftButtonDown"
                  MouseMove="NotchWrapper_MouseMove"
                  MouseLeftButtonUp="NotchWrapper_MouseLeftButtonUp"
                  MouseEnter="NotchWrapper_MouseEnter"
                  MouseLeave="NotchWrapper_MouseLeave"
                  MouseWheel="NotchWrapper_MouseWheel"
                  AllowDrop="True"
                  DragEnter="NotchWrapper_DragEnter"
                  DragOver="NotchWrapper_DragOver"
                  DragLeave="NotchWrapper_DragLeave"
                  Drop="NotchWrapper_DragDrop">
                <Grid.RenderTransform>
                    <ScaleTransform x:Name="NotchScale" ScaleX="1" ScaleY="1"/>
                </Grid.RenderTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Path x:Name="LeftEar" 
                      Grid.Column="0" 
                      Data="M 0,0 L 10,0 L 10,10 Q 10,0 0,0 Z" 
                      Fill="{StaticResource NotchGradient}" 
                      Width="11" Height="10" 
                      Margin="0,0,-1,0"
                      VerticalAlignment="Top"
                      RenderOptions.EdgeMode="Unspecified"/>

