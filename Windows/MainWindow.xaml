                        <Border x:Name="MediaBackground"
                                Grid.ColumnSpan="3"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Opacity="0"
                                Margin="-40,-26,-36,-48"
                                Panel.ZIndex="0"
                                IsHitTestVisible="False">
                            <Border.Effect>
                                <BlurEffect x:Name="ExpandedContentBlur" Radius="0" RenderingBias="Performance"/>
                            </Border.Effect>
                            <Border.OpacityMask>
                                <RadialGradientBrush GradientOrigin="0.30,0.56" Center="0.30,0.56" RadiusX="0.52" RadiusY="0.52">
                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                    <GradientStop Color="#99FFFFFF" Offset="0.35"/>
                                    <GradientStop Color="#44FFFFFF" Offset="0.65"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.95"/>
                                </RadialGradientBrush>
                            </Border.OpacityMask>
                            <Grid>
                                <Image x:Name="MediaBackgroundImage" Stretch="UniformToFill" Opacity="1.0"/>
                                <Rectangle x:Name="BrightnessDimOverlay" Fill="Black" Opacity="0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <Border x:Name="MediaBackground2"
                                Grid.ColumnSpan="3"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Opacity="0"
                                Margin="-16,-14,-18,-18"
                                Panel.ZIndex="0"
                                IsHitTestVisible="False">
                            <Border.OpacityMask>
                                <RadialGradientBrush GradientOrigin="0.22,0.36" Center="0.22,0.36" RadiusX="0.46" RadiusY="0.46">
                                    <GradientStop Color="#DDFFFFFF" Offset="0"/>
                                    <GradientStop Color="#77FFFFFF" Offset="0.35"/>
                                    <GradientStop Color="#33FFFFFF" Offset="0.65"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.95"/>
                                </RadialGradientBrush>
                            </Border.OpacityMask>
                            <Grid>
                                <Image x:Name="MediaBackgroundImage2" Stretch="UniformToFill" Opacity="1.0"/>
                                <Rectangle x:Name="BrightnessDimOverlay2" Fill="Black" Opacity="0" IsHitTestVisible="False"/>
                            </Grid>
                        </Border>

                        <!-- Lyrics blur background (blurred thumbnail glow at right side) -->
                        <Border x:Name="LyricsBlurBackground"
                                Grid.Column="2"
                                HorizontalAlignment="Stretch"
                                VerticalAlignment="Stretch"
                                Opacity="0"
                                Margin="-30,-20,-20,-30"
                                Panel.ZIndex="0"
                                Visibility="Collapsed"
                                IsHitTestVisible="False">
                            <Border.OpacityMask>
                                <RadialGradientBrush GradientOrigin="0.75,0.6" Center="0.75,0.6" RadiusX="0.55" RadiusY="0.6">
                                    <GradientStop Color="#BBFFFFFF" Offset="0"/>
                                    <GradientStop Color="#66FFFFFF" Offset="0.35"/>
                                    <GradientStop Color="#22FFFFFF" Offset="0.65"/>
                                    <GradientStop Color="#00FFFFFF" Offset="0.95"/>
                                </RadialGradientBrush>
                            </Border.OpacityMask>
                            <Grid>
                                <Image x:Name="LyricsBlurImage" Stretch="UniformToFill" Opacity="1.0"/>
                                <Image x:Name="LyricsBlurImageNext" Stretch="UniformToFill" Opacity="0"/>
                            </Grid>
                        </Border>

                        <Grid x:Name="MediaWidgetContainer" Grid.Column="0" Margin="-8,0,0,0" SizeChanged="MediaWidgetContainer_SizeChanged" Panel.ZIndex="1">

                            <Border x:Name="MediaWidget"
                                    Background="{StaticResource CardGradient}"
                                    CornerRadius="16"
                                    Padding="12,12,4,2"
                                    RenderOptions.ClearTypeHint="Enabled">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>


                                    <Grid Grid.Row="1" Margin="0,6,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                    <Border x:Name="ThumbnailBorder"
                                            Grid.Column="0" 
                                             Width="102" Height="102"
                                               VerticalAlignment="Center"
                                              CornerRadius="14"
                                              Background="#222222"
                                              Margin="0,0,8,0"
                                             Cursor="Hand"
                                             MouseLeftButtonDown="ThumbnailBorder_MouseLeftButtonDown"
                                             RenderTransformOrigin="0.5,0.5">
                                        <Border.RenderTransform>
                                            <ScaleTransform x:Name="ThumbnailScale" ScaleX="1" ScaleY="1"/>
                                        </Border.RenderTransform>
                                        <Grid Width="102" Height="102" ClipToBounds="True">

                                            <Image x:Name="ThumbnailImage" 
                                                   Width="102" Height="102"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   RenderTransformOrigin="0.5,0.5"
                                                   Visibility="Collapsed">
                                                <Image.Clip>
                                                    <RectangleGeometry RadiusX="14" RadiusY="14" Rect="0,0,102,102"/>
                                                </Image.Clip>
                                                <Image.RenderTransform>
                                                    <ScaleTransform x:Name="ThumbnailOutScale" ScaleX="1" ScaleY="1"/>
                                                </Image.RenderTransform>
                                                <Image.Effect>
                                                    <BlurEffect x:Name="ThumbnailOutBlur" Radius="0" RenderingBias="Performance"/>
                                                </Image.Effect>
                                            </Image>

                                            <Image x:Name="ThumbnailImageNext"
                                                   Width="102" Height="102"
                                                   Stretch="UniformToFill"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   RenderTransformOrigin="0.5,0.5"
                                                   Opacity="0"
                                                   IsHitTestVisible="False">
                                                <Image.Clip>
                                                    <RectangleGeometry RadiusX="14" RadiusY="14" Rect="0,0,102,102"/>
                                                </Image.Clip>
                                                <Image.RenderTransform>
                                                    <ScaleTransform x:Name="ThumbnailNextScale" ScaleX="1" ScaleY="1"/>
                                                </Image.RenderTransform>
                                                <Image.Effect>
                                                    <BlurEffect x:Name="ThumbnailNextBlur" Radius="0" RenderingBias="Performance"/>
                                                </Image.Effect>
                                            </Image>

                                            <TextBlock x:Name="ThumbnailFallback"
                                                       
                                                       FontSize="20"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                        </Grid>
                                    </Border>

                                    <Grid x:Name="MediaInfoSection"
                                          Grid.Column="1"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,0"
                                          SizeChanged="MediaInfoSection_SizeChanged">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <StackPanel Grid.Row="0" MaxWidth="340" RenderOptions.ClearTypeHint="Enabled" Margin="0,0,0,0">
                                            <StackPanel.OpacityMask>
                                                <LinearGradientBrush x:Name="TextFadeBrush" MappingMode="Absolute" StartPoint="0,0" EndPoint="340,0">
                                                    <GradientStop Color="Black" Offset="0"/>
                                                    <GradientStop Color="Black" Offset="0.8"/>
                                                    <GradientStop Color="Transparent" Offset="1"/>
                                                </LinearGradientBrush>
                                            </StackPanel.OpacityMask>

                                            <Canvas x:Name="TitleScrollContainer" Height="20" Width="340" ClipToBounds="True">
                                                <Grid x:Name="TitleMorphContainer" Canvas.Left="0" Canvas.Top="0">

                                                    <Grid Opacity="{Binding Opacity, ElementName=TrackTitle}">
                                                        <Grid.RenderTransform>
                                                            <TransformGroup>
                                                                <TranslateTransform x:Name="TitleMarqueeTranslate" X="0"/>
                                                                <TranslateTransform x:Name="TitleMorphTranslate" Y="0"/>
                                                            </TransformGroup>
                                                        </Grid.RenderTransform>
                                                        
                                                        <TextBlock Text="{Binding Text, ElementName=TrackTitle}"
                                                                   Style="{StaticResource TitleText}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="#80000000"
                                                                   Margin="0,1,0,0" />
                                                        
                                                        <TextBlock x:Name="TrackTitle"
                                                                   Text="No media playing"
                                                                   Style="{StaticResource TitleText}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource TrackTitleGradient}" />
                                                    </Grid>

                                                    <Grid Opacity="{Binding Opacity, ElementName=TrackTitleNext}">
                                                        <Grid.RenderTransform>
                                                            <TransformGroup>
                                                                <TranslateTransform x:Name="TitleMarqueeTranslateNext" X="0"/>
                                                                <TranslateTransform x:Name="TitleMorphTranslateNext" Y="0"/>
                                                            </TransformGroup>
                                                        </Grid.RenderTransform>
                                                        
                                                        <TextBlock Text="{Binding Text, ElementName=TrackTitleNext}"
                                                                   Style="{StaticResource TitleText}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="#80000000"
                                                                   Margin="0,1,0,0" />
                                                        
                                                        <TextBlock x:Name="TrackTitleNext"
                                                                   Text=""
                                                                   Style="{StaticResource TitleText}"
                                                                   FontSize="14"
                                                                   FontWeight="Bold"
                                                                   Foreground="{DynamicResource TrackTitleNextGradient}" />
                                                    </Grid>
                                                </Grid>
                                            </Canvas>

                                            <Canvas x:Name="ArtistScrollContainer" Height="18" Width="340" ClipToBounds="True" Margin="0,2,0,0">
                                                <Grid x:Name="ArtistMorphContainer" Canvas.Left="0" Canvas.Top="0">

                                                    <Grid Opacity="{Binding Opacity, ElementName=TrackArtist}">
                                                        <Grid.RenderTransform>
                                                            <TransformGroup>
                                                                <TranslateTransform x:Name="ArtistMarqueeTranslate" X="0"/>
                                                                <TranslateTransform x:Name="ArtistMorphTranslate" Y="0"/>
                                                            </TransformGroup>
                                                        </Grid.RenderTransform>
                                                        
                                                        <TextBlock Text="{Binding Text, ElementName=TrackArtist}"
                                                                   Style="{StaticResource SubtitleText}"
                                                                   FontWeight="Bold"
                                                                   Foreground="#80000000"
                                                                   Margin="0,1,0,0" />
                                                        
                                                        <TextBlock x:Name="TrackArtist" 
                                                                    Text="Artist name"
                                                                     Style="{StaticResource SubtitleText}"
                                                                    Foreground="#BFFFFFFF"
                                                                    FontWeight="Bold" />
                                                     </Grid>

                                                     <Grid Opacity="{Binding Opacity, ElementName=TrackArtistNext}">
                                                        <Grid.RenderTransform>
                                                            <TransformGroup>
                                                                <TranslateTransform x:Name="ArtistMarqueeTranslateNext" X="0"/>
                                                                <TranslateTransform x:Name="ArtistMorphTranslateNext" Y="0"/>
                                                            </TransformGroup>
                                                        </Grid.RenderTransform>
                                                        
                                                        <TextBlock Text="{Binding Text, ElementName=TrackArtistNext}"
                                                                   Style="{StaticResource SubtitleText}"
                                                                   FontWeight="Bold"
                                                                   Foreground="#80000000"
                                                                   Margin="0,1,0,0" />
                                                        
                                                         <TextBlock x:Name="TrackArtistNext" 
                                                                    Text=""
                                                                     Style="{StaticResource SubtitleText}"
                                                                    Foreground="#BFFFFFFF"
                                                                    FontWeight="Bold" />
                                                     </Grid>
                                                </Grid>
                                            </Canvas>
                                        </StackPanel>

                                        <Grid x:Name="MediaControls"
                                              Grid.Row="2"
                                              Width="{Binding ActualWidth, ElementName=ProgressSection}"
                                              VerticalAlignment="Top"
                                              HorizontalAlignment="Left"
                                              Margin="0,2,0,0">
                                            <Grid.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="1.2" Direction="270" Opacity="0.55" Color="Black" RenderingBias="Performance"/>
                                            </Grid.Effect>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                                <Border x:Name="PrevButton"
                                                        Grid.Column="0"
                                                        Background="Transparent"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="PrevButton_Click"
                                                        MouseEnter="MediaButton_MouseEnter"
                                                        MouseLeave="MediaButton_MouseLeave"
                                                        Width="32" Height="26"
                                                        Margin="0"
                                                        HorizontalAlignment="Left"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                <Viewbox Width="17" Height="12.5" Margin="0,-1,0,0">
                                                    <Canvas Width="19" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True">
                                                        <Path x:Name="PrevArrow0" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" Data="M10,0 L0,8 L10,16 Z" Canvas.Left="16" Canvas.Top="0" Opacity="0">
                                                            <Path.RenderTransform>
                                                                <TranslateTransform X="0" Y="0"/>
                                                            </Path.RenderTransform>
                                                        </Path>
