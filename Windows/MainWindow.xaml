                                                                      Canvas.Left="0"
                                                                      Canvas.Top="1"/>
                                                            </Canvas>
                                                            <Canvas x:Name="PlayIcon" Width="46" Height="46" Visibility="Collapsed" RenderTransformOrigin="0.5,0.5">
                                                                <Canvas.RenderTransform>
                                                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                                </Canvas.RenderTransform>
                                                                <Path x:Name="PlayIconPath"
                                                                      Width="48"
                                                                      Height="45.975"
                                                                      Fill="White"
                                                                      Stretch="Fill"
                                                                      Data="{StaticResource PlayButtonSvgIcon}"
                                                                      Canvas.Left="0"
                                                                      Canvas.Top="1"/>
                                                            </Canvas>
                                                        </Grid>
                                                    </Viewbox>
                                                </Border>

                                                <Border x:Name="NextButton"
                                                        Grid.Column="2"
                                                        Background="Transparent"
                                                        CornerRadius="8"
                                                        Cursor="Hand"
                                                        MouseLeftButtonDown="NextButton_Click"
                                                        MouseEnter="MediaButton_MouseEnter"
                                                        MouseLeave="MediaButton_MouseLeave"
                                                        Width="32" Height="26"
                                                        Margin="0"
                                                        HorizontalAlignment="Right"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Border.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Border.RenderTransform>
                                                <Viewbox Width="17" Height="12.5" Margin="0,-1,0,0">
                                                    <Canvas Width="19" Height="16" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True">
                                                        <Path x:Name="NextArrow0" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M0,0 L10,8 L0,16 Z" Canvas.Left="-8" Canvas.Top="0" Opacity="0">
