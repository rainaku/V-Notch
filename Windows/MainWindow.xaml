                                                  MouseEnter="ProgressBar_MouseEnter"
                                                  MouseLeftButtonDown="ProgressBar_MouseDown"
                                                  MouseMove="ProgressBar_MouseMove"
                                                  MouseLeftButtonUp="ProgressBar_MouseUp"
                                                  MouseLeave="ProgressBar_MouseLeave"
                                                  RenderTransformOrigin="0.5,0.5">
                                                <Grid.RenderTransform>
                                                    <ScaleTransform x:Name="ProgressBarMainScale" ScaleY="1"/>
                                                </Grid.RenderTransform>

                                                <Border x:Name="ProgressBarBg" Background="#262626" Height="4" CornerRadius="2" VerticalAlignment="Center" SizeChanged="ProgressBarBg_SizeChanged">
                                                    <Grid>
                                                        <Grid.Clip>
                                                            <RectangleGeometry x:Name="ProgressBarClip" RadiusX="2" RadiusY="2"/>
                                                        </Grid.Clip>
                                                        <Border x:Name="ProgressBar" 
                                                                Height="4" 
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Center"
                                                                RenderTransformOrigin="0,0.5">
                                                            <Border.Background>
                                                                <LinearGradientBrush x:Name="ProgressBarGradient" StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop x:Name="ProgressBarGradientStart" Color="White" Offset="0"/>
                                                                    <GradientStop x:Name="ProgressBarGradientEnd" Color="#999999" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Border.RenderTransform>
                                                                <ScaleTransform x:Name="ProgressBarScale" ScaleX="0"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <Border x:Name="IndeterminateProgress" 
                                                        Background="White" 
                                                        Height="4" 
                                                        CornerRadius="2"
                                                        HorizontalAlignment="Stretch"
                                                        VerticalAlignment="Center"
                                                        Opacity="0"
                                                        Visibility="Collapsed"/>
                                            </Grid>

                                            <TextBlock x:Name="RemainingTimeText" 
                                                       Grid.Row="1"
                                                       Grid.Column="2"
                                                       Margin="6,2,0,0"
                                                       Text="0:00" 
                                                       Style="{StaticResource ProgressTimeText}"
                                                       VerticalAlignment="Center"/>

                                            <TextBlock x:Name="CurrentTimeText" 
                                                       Grid.Row="1"
                                                       Grid.Column="0"
                                                       Margin="0,2,6,0"
                                                       Text="0:00" 
                                                       Style="{StaticResource ProgressTimeText}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Grid>

                                    <StackPanel x:Name="InlineControls"
                                                Grid.Column="2" 
                                                Orientation="Vertical"
                                                VerticalAlignment="Center" 
                                                HorizontalAlignment="Right"
                                                Visibility="Collapsed"
                                                Opacity="0"
                                                Margin="10,5,0,0"
                                                RenderTransformOrigin="0.5,0.5">
                                        <StackPanel.RenderTransform>
                                            <TranslateTransform x:Name="InlineControlsTranslate" X="0" Y="10"/>
                                        </StackPanel.RenderTransform>
                                        <StackPanel.Effect>
                                            <DropShadowEffect BlurRadius="6" ShadowDepth="1.2" Direction="270" Opacity="0.5" Color="Black" RenderingBias="Performance"/>
                                        </StackPanel.Effect>

                                        <Grid x:Name="VolumeControlArea" Margin="0,0,0,8" HorizontalAlignment="Right">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock x:Name="VolumeIcon" Text="&#xE767;" FontFamily="Segoe MDL2 Assets" Foreground="#888888" FontSize="14" Margin="0,0,4,0" VerticalAlignment="Center" Cursor="Hand" MouseLeftButtonDown="VolumeIcon_MouseDown" MouseEnter="VolumeIcon_MouseEnter" MouseLeave="VolumeIcon_MouseLeave" RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <ScaleTransform x:Name="VolumeIconScale" ScaleX="1" ScaleY="1"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                    <Grid x:Name="VolumeBarContainer" Width="100" Height="20" Cursor="Hand" 
                                                          Background="Transparent"
                                                          MouseLeftButtonDown="VolumeBar_MouseDown" 
                                                          MouseMove="VolumeBar_MouseMove"
                                                          MouseLeftButtonUp="VolumeBar_MouseUp">
                                                        <Border Background="#333333" Height="4" CornerRadius="2" VerticalAlignment="Center"/>
                                                        <Border x:Name="VolumeBarFront" 
                                                                Height="4" 
                                                                CornerRadius="2" 
                                                                VerticalAlignment="Center" 
                                                                HorizontalAlignment="Stretch" 
                                                                RenderTransformOrigin="0,0.5">
                                                            <Border.Background>
                                                                <LinearGradientBrush x:Name="VolumeBarGradient" StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop x:Name="VolumeBarGradientStart" Color="White" Offset="0"/>
                                                                    <GradientStop x:Name="VolumeBarGradientEnd" Color="#999999" Offset="1"/>
                                                                </LinearGradientBrush>
                                                            </Border.Background>
                                                            <Border.RenderTransform>
                                                                <ScaleTransform x:Name="VolumeBarScale" ScaleX="0.5"/>
                                                            </Border.RenderTransform>
                                                        </Border>
                                                    </Grid>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">

                                        <Border x:Name="InlinePrevButton"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="InlinePrevButton_Click"
                                                MouseEnter="MediaButton_MouseEnter"
                                                MouseLeave="MediaButton_MouseLeave"
                                                Width="27" Height="30"
                                                Margin="0,0,11,0"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="InlinePrevScale" ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Canvas Width="26" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True" Margin="0,-1,0,0">

                                                <Path x:Name="InlinePrevArrow0" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" Data="M10,0 L0,8 L10,16 Z"
                                                      Canvas.Left="16" Canvas.Top="0" Opacity="0">
                                                    <Path.RenderTransform>
                                                        <TranslateTransform X="0" Y="0"/>
                                                    </Path.RenderTransform>
                                                </Path>

                                                <Path x:Name="InlinePrevArrow2" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" Data="M10,0 L0,8 L10,16 Z"
                                                      Canvas.Left="8" Canvas.Top="0">
                                                    <Path.RenderTransform>
                                                        <TranslateTransform X="0" Y="0"/>
                                                    </Path.RenderTransform>
                                                </Path>

                                                <Path x:Name="InlinePrevArrow1" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" Data="M10,0 L0,8 L10,16 Z"
                                                      Canvas.Left="0" Canvas.Top="0">
                                                    <Path.RenderTransform>
                                                        <TranslateTransform X="0" Y="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Canvas>
                                        </Border>

                                        <Border x:Name="InlinePlayPauseButton"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="InlinePlayPauseButton_Click"
                                                MouseEnter="MediaButton_MouseEnter"
                                                MouseLeave="MediaButton_MouseLeave"
                                                Width="27" Height="30"
                                                Margin="0"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="InlinePlayPauseScale" ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">

                                                <Canvas x:Name="InlinePauseIcon" Width="16" Height="18" Visibility="Visible"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Canvas.RenderTransform>
                                                        <ScaleTransform x:Name="InlinePauseIconScale" ScaleX="1" ScaleY="1"/>
                                                    </Canvas.RenderTransform>
                                                    <Path x:Name="InlinePauseIconPath"
                                                          Width="16"
                                                          Height="16"
                                                          Fill="White"
                                                          Stretch="Fill"
                                                          Data="{StaticResource PauseButtonSvgIcon}"
                                                          Canvas.Left="0"
                                                          Canvas.Top="1.5"/>
                                                </Canvas>

                                                <Canvas x:Name="InlinePlayIcon" Width="16" Height="18" Visibility="Collapsed"
                                                        RenderTransformOrigin="0.5,0.5">
                                                    <Canvas.RenderTransform>
                                                        <ScaleTransform x:Name="InlinePlayIconScale" ScaleX="1" ScaleY="1"/>
                                                    </Canvas.RenderTransform>
                                                    <Path x:Name="InlinePlayIconPath"
                                                          Width="16"
                                                          Height="16"
                                                          Fill="White"
                                                          Stretch="Fill"
                                                          Data="{StaticResource PlayButtonSvgIcon}"
                                                          Canvas.Left="0"
                                                          Canvas.Top="1.5"/>
                                                </Canvas>
                                            </Grid>
                                        </Border>

                                        <Border x:Name="InlineNextButton"
                                                Background="Transparent"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="InlineNextButton_Click"
                                                MouseEnter="MediaButton_MouseEnter"
                                                MouseLeave="MediaButton_MouseLeave"
                                                Width="27" Height="30"
                                                Margin="11,0,0,0"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform x:Name="InlineNextScale" ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Canvas Width="26" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center" ClipToBounds="True" Margin="0,-1,0,0">

                                                <Path x:Name="InlineNextArrow0" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" Data="M0,0 L10,8 L0,16 Z"
                                                      Canvas.Left="-8" Canvas.Top="0" Opacity="0">
                                                    <Path.RenderTransform>
                                                        <TranslateTransform X="0" Y="0"/>
                                                    </Path.RenderTransform>
                                                </Path>

                                                <Path x:Name="InlineNextArrow1" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" Data="M0,0 L10,8 L0,16 Z"
                                                      Canvas.Left="0" Canvas.Top="0">
                                                    <Path.RenderTransform>
                                                        <TranslateTransform X="0" Y="0"/>
                                                    </Path.RenderTransform>
                                                </Path>

                                                <Path x:Name="InlineNextArrow2" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" Data="M0,0 L10,8 L0,16 Z"
                                                      Canvas.Left="8" Canvas.Top="0">
                                                    <Path.RenderTransform>
                                                        <TranslateTransform X="0" Y="0"/>
                                                    </Path.RenderTransform>
                                                </Path>
                                            </Canvas>
                                        </Border>
                                    </StackPanel>
                                    </StackPanel>
                                </Grid>

                            </Grid>
                        </Border>

                    </Grid>

                        <Grid Grid.Column="2" Margin="0,20,-1,0" VerticalAlignment="Center" HorizontalAlignment="Right" Grid.IsSharedSizeScope="True" RenderOptions.ClearTypeHint="Enabled">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            
                            <Border x:Name="CalendarWidget"
                                    Grid.Row="0" 
                                    Background="{StaticResource CardGradient}"
                                    CornerRadius="16"
                                    Padding="10,8"
                                    RenderTransformOrigin="0.5,0.5"
                                    MouseEnter="CalendarWidget_MouseEnter"
                                    MouseLeave="CalendarWidget_MouseLeave"
                                    MouseWheel="CalendarWidget_MouseWheel">
                                <Border.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="CalendarWidgetScale" ScaleX="1" ScaleY="1"/>
                                        <TranslateTransform x:Name="CalendarWidgetTranslate" Y="0"/>
                                    </TransformGroup>
                                </Border.RenderTransform>
                                <Grid VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    
                                    <TextBlock x:Name="MonthText"
                                               Grid.Column="0"
                                               Text="Dec"
                                               Style="{StaticResource TitleText}"
                                               FontSize="15"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Margin="-3,0,12,0"
                                               RenderTransformOrigin="0,0.5"
                                               Panel.ZIndex="10"
                                               TextOptions.TextRenderingMode="Grayscale"
                                               TextOptions.TextHintingMode="Animated">
                                        <TextBlock.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="MonthTextScale" ScaleX="1" ScaleY="1"/>
                                                <TranslateTransform x:Name="MonthTextTranslate" X="0" Y="0"/>
                                            </TransformGroup>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <TextBlock x:Name="DayText"
                                               Grid.Column="0"
                                               Text="14"
                                               Style="{StaticResource TitleText}"
                                               FontSize="18"
                                               HorizontalAlignment="Center"
                                               Visibility="Collapsed"/>

                                    <Grid Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                                        <Grid.OpacityMask>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="Transparent" Offset="0"/>
                                                <GradientStop Color="Black" Offset="0.12"/>
                                                <GradientStop Color="Black" Offset="0.92"/>
                                                <GradientStop Color="Transparent" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Grid.OpacityMask>

                                        <Canvas x:Name="CalendarStripClip"
                                                Width="95"
                                                Height="48"
                                                ClipToBounds="True">
                                            <Grid x:Name="CalendarDayStrip" HorizontalAlignment="Left">
                                                <Grid.RenderTransform>
                                                    <TranslateTransform x:Name="CalendarStripTranslate" X="0"/>
                                                </Grid.RenderTransform>

                                                <Border x:Name="CalendarMainHighlight"
                                                        Width="24" Height="24"
                                                        Background="White"
                                                        CornerRadius="12"
                                                        RenderTransformOrigin="0.5,0.5"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Top"
                                                        Margin="0,15,0,0">
                                                    <Border.RenderTransform>
                                                        <TransformGroup>
                                                            <ScaleTransform x:Name="CalendarHighlightScale" ScaleX="1" ScaleY="1"/>
                                                            <TranslateTransform x:Name="CalendarHighlightTranslate" X="0"/>
                                                        </TransformGroup>
                                                    </Border.RenderTransform>
                                                </Border>

                                                <StackPanel Orientation="Vertical">
                                                    <StackPanel x:Name="WeekDaysPanel" Orientation="Horizontal" Margin="0,0,0,4"/>
                                                    <StackPanel x:Name="WeekNumbers" Orientation="Horizontal"/>
                                                </StackPanel>
                                            </Grid>
                                        </Canvas>
                                    </Grid>
                                </Grid>
                            </Border>

                           
                            <Grid x:Name="GreetingSection" Grid.Row="1" Margin="4,-6,0,0">
                                <Grid.Effect>
                                    <BlurEffect x:Name="CalendarGreetingContextBlur" Radius="0" RenderingBias="Performance"/>
                                </Grid.Effect>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Border Grid.Column="0" Margin="0,0,12,0"/> 
                                
                                <TextBlock x:Name="EventText"
                                           Grid.Column="1"
                                           Text="Enjoy your day!"
                                           Style="{StaticResource SmallText}"
                                           FontSize="10"
                                           FontWeight="Bold"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Left"
                                           Foreground="#99FFFFFF"
                                           TextWrapping="Wrap"/>
                            </Grid>

                            <!-- Synced Lyrics Widget (replaces calendar when lyrics available) -->
                            <Border x:Name="LyricsWidget"
                                    Grid.Row="0" Grid.RowSpan="2"
                                    Background="Transparent"
                                    CornerRadius="16"
                                    Padding="4,2,7,2"
                                    Margin="0,0,10,6"
                                    Visibility="Collapsed"
                                    Opacity="0"
                                    VerticalAlignment="Stretch"
                                    HorizontalAlignment="Stretch"
                                    ClipToBounds="True">
                                <Border.OpacityMask>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="Black" Offset="0.12"/>
                                        <GradientStop Color="Black" Offset="0.88"/>
                                        <GradientStop Color="Transparent" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.OpacityMask>
                                <Grid ClipToBounds="True" VerticalAlignment="Center">
                                    <!-- Track info placeholder (shown before first lyric line) -->
                                    <StackPanel x:Name="LyricsPlaceholderPanel"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Stretch"
                                                Opacity="0"
                                                Visibility="Collapsed">
                                        <TextBlock x:Name="LyricsPlaceholderTitle"
                                                   Text=""
                                                   FontSize="12.5"
                                                   FontWeight="Bold"
                                                   Foreground="#EEFFFFFF"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Right"
                                                   HorizontalAlignment="Stretch"
                                                   FontFamily="{StaticResource MainSystemFont}"
                                                   TextOptions.TextFormattingMode="Ideal"/>
                                        <TextBlock x:Name="LyricsPlaceholderArtist"
                                                   Text=""
                                                   FontSize="10.5"
                                                   FontWeight="SemiBold"
                                                   Foreground="#99FFFFFF"
                                                   TextTrimming="CharacterEllipsis"
                                                   TextAlignment="Right"
                                                   HorizontalAlignment="Stretch"
                                                   Margin="0,2,0,0"
                                                   FontFamily="{StaticResource MainSystemFont}"
                                                   TextOptions.TextFormattingMode="Ideal"/>
                                        <StackPanel.RenderTransform>
                                            <TranslateTransform x:Name="LyricsPlaceholderTranslate" Y="0"/>
                                        </StackPanel.RenderTransform>
                                    </StackPanel>
                                    <!-- Lyric line A -->
                                    <TextBlock x:Name="LyricTextA"
                                               Text=""
                                               Style="{StaticResource SubtitleText}"
                                               FontSize="12.5"
                                               FontWeight="Bold"
                                               Foreground="#EEFFFFFF"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="110"
                                               TextAlignment="Right"
                                               TextOptions.TextFormattingMode="Ideal"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Stretch"
                                               Opacity="0">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="LyricTranslateA" Y="0"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                    <!-- Lyric line B -->
                                    <TextBlock x:Name="LyricTextB"
                                               Text=""
                                               Style="{StaticResource SubtitleText}"
                                               FontSize="12.5"
                                               FontWeight="Bold"
                                               Foreground="#EEFFFFFF"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="110"
                                               TextAlignment="Right"
                                               TextOptions.TextFormattingMode="Ideal"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Stretch"
                                               Opacity="0">
                                        <TextBlock.RenderTransform>
                                            <TranslateTransform x:Name="LyricTranslateB" Y="0"/>
                                        </TextBlock.RenderTransform>
                                    </TextBlock>
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>

                    <Grid x:Name="SecondaryContent" 
                          Opacity="0" 
                          Visibility="Collapsed"
                          Margin="12,10,12,12"
                          MouseLeftButtonDown="SecondaryContent_Click"
                          RenderOptions.ClearTypeHint="Enabled">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="3*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="CameraSection"
                                Grid.Column="0" 
                                Background="#1A1A1A" 
                                CornerRadius="12" 
                                Margin="0,0,8,0" 
                                ClipToBounds="True"
                                Cursor="Hand"
                                RenderTransformOrigin="0.5,0.5"
                                SizeChanged="CameraSection_SizeChanged"
                                MouseLeftButtonDown="CameraSection_Click">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="CameraSectionScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Grid>

                                <Image x:Name="CameraPreviewImage"
                                       Stretch="UniformToFill"
                                       Opacity="0"
                                       RenderTransformOrigin="0.5,0.5">
                                    <Image.RenderTransform>
                                        <ScaleTransform x:Name="CameraPreviewScale" ScaleX="1.06" ScaleY="1.06"/>
                                    </Image.RenderTransform>
                                    <Image.Effect>
                                        <BlurEffect x:Name="CameraPreviewBlur" Radius="16" RenderingBias="Performance"/>
                                    </Image.Effect>
                                </Image>

                                <Border x:Name="CameraOverlay" Background="#40000000">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <Path Data="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0 M20 4h-3.17L15 2H9L7.17 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2z" 
                                              Fill="White" Width="20" Height="20" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock x:Name="CameraLabel" Text="Camera" Style="{StaticResource SmallText}" FontWeight="Bold" Foreground="White" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <Border x:Name="CameraErrorOverlay" Background="#60000000" Visibility="Collapsed">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                                        <Path Data="M12 9v4m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 17c-.77 1.333.192 3 1.732 3z" 
                                              Stroke="White" StrokeThickness="1.5" Width="18" Height="18" Stretch="Uniform" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Cannot detect camera device" Style="{StaticResource SmallText}" FontSize="9"
                                                   Foreground="White" HorizontalAlignment="Center" Margin="0,4,0,0" TextWrapping="Wrap" TextAlignment="Center"/>
                                        <TextBlock Text="click to try again" Style="{StaticResource SmallText}" FontSize="8"
                                                   Foreground="#99FFFFFF" HorizontalAlignment="Center" FontStyle="Italic"/>
                                    </StackPanel>
                                </Border>

                            </Grid>
                        </Border>

                        <Border x:Name="FileShelf"
                                Grid.Column="1" 
                                Background="#1A1A1A" 
                                CornerRadius="16" 
                                AllowDrop="True"
                                BorderThickness="0"
                                DragEnter="FileShelf_DragEnter" 
                                DragOver="FileShelf_DragOver"
                                DragLeave="FileShelf_DragLeave"
                                Drop="FileShelf_Drop">
                            <Grid x:Name="FileShelfGrid" 
                                  Background="Transparent"
                                  MouseLeftButtonDown="FileShelf_MouseDown"
                                  MouseMove="FileShelf_MouseMove"
                                  MouseLeftButtonUp="FileShelf_MouseUp"
                                  LostMouseCapture="FileShelfGrid_LostMouseCapture">

                                <Rectangle x:Name="FileShelfDashedBorder"
                                           Stroke="#333333" 
                                           StrokeThickness="1.5" 
                                           StrokeDashArray="4 3" 
                                           RadiusX="16" RadiusY="16"/>

                                <TextBlock x:Name="ShelfPlaceholder"
                                           Text=""
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"
                                           Style="{StaticResource SubtitleText}"/>

                                <Border HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="0,10,12,0"
                                        Panel.ZIndex="10"
                                        Background="#22000000"
                                        BorderBrush="#2FFFFFFF"
                                        BorderThickness="1"
                                        CornerRadius="9"
                                        Padding="7,3">
                                    <TextBlock x:Name="ShelfCountText"
                                               Text="0/30"
                                               Style="{StaticResource SmallText}"
                                               Foreground="White"/>
                                </Border>

                                <TextBlock x:Name="ShelfStatusText"
                                           Text="Shelf full"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Top"
                                           Margin="16,10,16,0"
                                           Panel.ZIndex="10"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"
                                           Style="{StaticResource SmallText}"
                                           Foreground="#FFC478"/>

                                <ScrollViewer x:Name="ShelfScrollViewer" 
                                             Background="Transparent" 
                                             HorizontalScrollBarVisibility="Auto" 
                                             VerticalScrollBarVisibility="Disabled" 
                                             Padding="0"
                                             PreviewMouseWheel="ShelfScrollViewer_PreviewMouseWheel">
                                    <ScrollViewer.Resources>

                                        <Style TargetType="ScrollBar">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Width" Value="6"/>
                                            <Setter Property="Height" Value="4"/>
                                            <Setter Property="MinHeight" Value="4"/>
                                            <Setter Property="MinWidth" Value="4"/>
                                            <Setter Property="Opacity" Value="0"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ScrollBar">
                                                        <Grid Background="Transparent">
                                                            <Track x:Name="PART_Track" IsDirectionReversed="False">
                                                                <Track.Thumb>
                                                                    <Thumb>
                                                                        <Thumb.Template>
                                                                            <ControlTemplate TargetType="Thumb">
                                                                                <Border Background="#60FFFFFF" 
                                                                                        CornerRadius="2" 
                                                                                        Margin="0,1"
                                                                                        MinWidth="20"/>
                                                                            </ControlTemplate>
                                                                        </Thumb.Template>
                                                                    </Thumb>
                                                                </Track.Thumb>
                                                            </Track>
                                                        </Grid>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Trigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.EnterActions>
                                                    <Trigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.4" BeginTime="0:0:0.8"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </Trigger.ExitActions>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ScrollViewer.Resources>
                                    <WrapPanel x:Name="ShelfItemsContainer" 
                                               Background="Transparent"
                                               Orientation="Vertical" 
                                               Height="120"
                                               Margin="8,4"
                                               VerticalAlignment="Center"/>
                                </ScrollViewer>

                                <Canvas x:Name="SelectionCanvas" 
                                        Visibility="Collapsed" 
                                        IsHitTestVisible="False" 
                                        Panel.ZIndex="1000"
                                        HorizontalAlignment="Stretch" 
                                        VerticalAlignment="Stretch"
                                        Background="Transparent">
                                    <Border x:Name="SelectionRect" Background="#24FFFFFF" BorderBrush="#99FFFFFF" BorderThickness="1" HorizontalAlignment="Left" VerticalAlignment="Top" CornerRadius="3"/>
                                </Canvas>

                                <!-- Shelf Upload Limit Unlock Banner -->
                                <Border x:Name="ShelfUnlockBanner"
                                        Visibility="Collapsed"
                                        Background="#E6181818"
                                        CornerRadius="14"
                                        Padding="16,12"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Panel.ZIndex="3000"
                                        MaxWidth="340">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock x:Name="ShelfUnlockMessageText"
                                                   Text=""
                                                   Style="{StaticResource SubtitleText}"
                                                   FontSize="11"
                                                   Foreground="#FFC478"
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Border Background="#333333"
                                                    CornerRadius="8"
                                                    Padding="12,6"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="ShelfUnlockButton_Click"
                                                    Margin="0,0,8,0">
                                                <TextBlock x:Name="ShelfUnlockButtonText"
                                                           Text="Unlock Limit"
                                                           Foreground="#AAAAAA"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           FontFamily="{StaticResource MainSystemFont}"/>
                                            </Border>
                                            <Border Background="#333333"
                                                    CornerRadius="8"
                                                    Padding="12,6"
                                                    Cursor="Hand"
                                                    MouseLeftButtonDown="ShelfUnlockDismiss_Click">
                                                <TextBlock x:Name="ShelfUnlockDismissText"
                                                           Text="Dismiss"
                                                           Foreground="#AAAAAA"
                                                           FontSize="11"
                                                           FontWeight="Bold"
                                                           FontFamily="{StaticResource MainSystemFont}"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock x:Name="ShelfUnlockSettingsHint"
                                                   Text="You can also customize this in Settings."
                                                   Style="{StaticResource SmallText}"
                                                   FontSize="9.5"
                                                   Foreground="#777777"
                                                   TextAlignment="Center"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border x:Name="HoverGlow"
                            CornerRadius="0,0,20,20"
                            Opacity="0"
                            IsHitTestVisible="False">
                        <Border.Background>
                            <RadialGradientBrush GradientOrigin="0.5,0" Center="0.5,0" RadiusX="0.9" RadiusY="1.1">
                                <GradientStop Color="#28FFFFFF" Offset="0"/>
                                <GradientStop Color="#08FFFFFF" Offset="0.65"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </RadialGradientBrush>
                        </Border.Background>
                    </Border>
                    </Grid>
                </Grid>
            </Border>
        </Border>

            <!-- Inline tooltip outside clip region to avoid being hidden/cropped -->
            <Border x:Name="UpdateInlineTooltip"
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,34,10,0"
                    Visibility="Collapsed"
                    Opacity="0"
                    IsHitTestVisible="False"
                    Panel.ZIndex="3000">
                <Border CornerRadius="10"
                        BorderBrush="#33FFFFFF"
                        BorderThickness="1"
                        Padding="10,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#F0222222" Offset="0"/>
                            <GradientStop Color="#EA111111" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel>
                        <DockPanel LastChildFill="True">
                            <Ellipse Width="7" Height="7" Fill="#30D158" Margin="0,0,7,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Ready To Update"
                                       Foreground="White"
                                       FontSize="11.5"
                                       FontWeight="SemiBold"
                                       FontFamily="{StaticResource MainSystemFont}"/>
                        </DockPanel>
                        <TextBlock x:Name="UpdateInlineStatusText"
                                   Text="Version v-"
                                   Foreground="#CCFFFFFF"
                                   FontSize="10.5"
                                   FontWeight="Bold"
                                   Margin="0,4,0,0"
                                   FontFamily="{StaticResource MainSystemFont}"/>
                        <TextBlock x:Name="UpdateInlineHintText"
                                   Text="Click to download &amp; install"
                                   Foreground="#99FFFFFF"
                                   FontSize="9.5"
                                   FontWeight="Bold"
                                   Margin="0,5,0,0"
                                   FontFamily="{StaticResource MainSystemFont}"/>
                    </StackPanel>
                </Border>
            </Border>

            <Path x:Name="RightEar" 
                  Grid.Column="2" 
                  Data="M 0,10 L 0,0 L 11,0 Q 1,0 1,10 Z" 
                  Fill="{StaticResource NotchGradient}" 
                  Width="11" Height="10" 
                  Margin="-1,0,0,0"
                  VerticalAlignment="Top"
                  RenderOptions.EdgeMode="Unspecified"/>
        </Grid>
    </Grid>
</Grid>
</Window>
