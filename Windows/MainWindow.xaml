                                                                <TranslateTransform X="0" Y="0"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                        <Path x:Name="NextArrow1" Fill="White" Stroke="White" StrokeThickness="0.9" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" Data="M0,0 L10,8 L0,16 Z" Canvas.Left="0" Canvas.Top="0">
                                                            <Path.RenderTransform>
                                                                <TranslateTransform X="0" Y="0"/>
                                                            </Path.RenderTransform>
