                                                            <Path.RenderTransform>
                                                                <TranslateTransform X="0" Y="0"/>
                                                            </Path.RenderTransform>
                                                        </Path>
                                                    </Canvas>
                                                    </Viewbox>
                                                </Border>
                                        </Grid>

                                        <Grid x:Name="ProgressSection" Grid.Row="1" Margin="0,8,0,0" Visibility="Visible">
