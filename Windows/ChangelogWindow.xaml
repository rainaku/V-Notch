<Window x:Class="VNotch.Windows.ChangelogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="What's New in V-Notch" 
        Height="600" 
        Width="700"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        MinHeight="400"
        MinWidth="500"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VersionButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#2A2A2A"/>
                </Trigger>
                <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource Self}}" Value="True">
                    <Setter Property="Background" Value="#0066FF"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#1A1A1A" 
            BorderBrush="#333333" 
            BorderThickness="1" 
            CornerRadius="12">
        
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="3" Opacity="0.7" BlurRadius="20"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Background="#252525" 
                    CornerRadius="12,12,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="50">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" 
                                Orientation="Vertical" 
                                VerticalAlignment="Center"
                                Margin="20,0,0,0">
                        <TextBlock x:Name="TitleText"
                                   Text="What's New"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock x:Name="SubtitleText"
                                   Text="Recent updates and changes"
                                   FontSize="11"
                                   Foreground="#888888"
                                   Margin="0,2,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Style="{StaticResource CloseButton}"
                            Content="✕"
                            Click="CloseButton_Click"
                            Margin="0,0,12,0"/>
                </Grid>
            </Border>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/>
                    <ColumnDefinition Width="1"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Version List Sidebar -->
                <Border Grid.Column="0" 
                        Background="#1E1E1E"
                        BorderBrush="#2A2A2A"
                        BorderThickness="0,1,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="VERSIONS"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#666666"
                                   Margin="12,16,12,8"/>

                        <ScrollViewer Grid.Row="1" 
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="VersionListPanel" Margin="8,0,8,16"/>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Divider -->
                <Border Grid.Column="1" Background="#2A2A2A"/>

                <!-- Changelog Content -->
                <Border Grid.Column="2" 
                        Background="#1A1A1A"
                        CornerRadius="0,0,12,0">
                    <ScrollViewer x:Name="ContentScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Padding="24,20,24,24">
                        <StackPanel x:Name="ContentPanel">
                            <!-- Loading State -->
                            <TextBlock x:Name="LoadingText"
                                       Text="Loading changelog..."
                                       FontSize="14"
                                       Foreground="#888888"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Margin="0,40,0,0"/>

                            <!-- Error State -->
                            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed">
                                <TextBlock Text="⚠"
                                           FontSize="32"
                                           Foreground="#FFA500"
                                           HorizontalAlignment="Center"
                                           Margin="0,40,0,12"/>
                                <TextBlock x:Name="ErrorText"
                                           Text="Failed to load changelog"
                                           FontSize="14"
                                           Foreground="#888888"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Content Container -->
                            <StackPanel x:Name="ChangelogContent" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
