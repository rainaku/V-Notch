<Window x:Class="VNotch.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="V-Notch Setup"
        Width="680"
        Height="520"
        MinWidth="520"
        MinHeight="420"
        MaxWidth="900"
        MaxHeight="700"
        WindowStyle="None"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        WindowStartupLocation="CenterScreen"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="{StaticResource SFProDisplay}"
        FontWeight="Bold"
        Loaded="Window_Loaded"
        SizeChanged="Window_SizeChanged">
    
    <Window.Resources>
        <!-- Apple-like easing -->
        <KeySpline x:Key="AppleEase">0.16,1 0.3,1</KeySpline>
        
        <!-- Storyboard for window entrance -->
        <Storyboard x:Key="WindowEntranceStoryboard">
            <!-- Window scale and opacity -->
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                           From="0.96" To="1.0"
                           Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                           Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                           From="0.96" To="1.0"
                           Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="MainBorder"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.6">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- Icon reveal -->
            <DoubleAnimation Storyboard.TargetName="IconContainer"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           BeginTime="0:0:0"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="IconTranslate"
                           Storyboard.TargetProperty="Y"
                           From="8" To="0"
                           BeginTime="0:0:0"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- Headline reveal -->
            <DoubleAnimation Storyboard.TargetName="HeadlineText"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           BeginTime="0:0:0.08"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="HeadlineTranslate"
                           Storyboard.TargetProperty="Y"
                           From="8" To="0"
                           BeginTime="0:0:0.08"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- Body text reveal -->
            <DoubleAnimation Storyboard.TargetName="BodyText"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           BeginTime="0:0:0.16"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="BodyTranslate"
                           Storyboard.TargetProperty="Y"
                           From="8" To="0"
                           BeginTime="0:0:0.16"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            
            <!-- Buttons reveal -->
            <DoubleAnimation Storyboard.TargetName="ButtonPanel"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           BeginTime="0:0:0.24"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ButtonTranslate"
                           Storyboard.TargetProperty="Y"
                           From="8" To="0"
                           BeginTime="0:0:0.24"
                           Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="6"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Page transition storyboard -->
        <Storyboard x:Key="PageTransitionStoryboard">
            <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                           Storyboard.TargetProperty="Opacity"
                           From="0" To="1"
                           Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        
        <!-- Button hover style -->
        <Style x:Key="SetupButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SFProDisplay}"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="#E5E5E5"
                                                          Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="#FFFFFF"
                                                          Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Secondary button style -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SFProDisplay}"/>
            <Setter Property="Padding" Value="24,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="#2A2A2A"
                                                          Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetName="border"
                                                          Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                          To="#1A1A1A"
                                                          Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0F0F0F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid>
        <Border x:Name="MainBorder"
                CornerRadius="24"
                Background="#0A0A0C"
                BorderBrush="Transparent"
                BorderThickness="0"
                RenderTransformOrigin="0.5,0.5"
                Opacity="0"
                ClipToBounds="True">
            <Border.RenderTransform>
                <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
            </Border.RenderTransform>
            
            <Grid Background="Transparent">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Inner border for subtle outline -->
                <Border Grid.RowSpan="3" 
                        CornerRadius="23" 
                        BorderBrush="#1AFFFFFF" 
                        BorderThickness="1"
                        IsHitTestVisible="False"/>
                
                <!-- Title bar -->
                <Border Grid.Row="0" Height="58" Background="#08080A" CornerRadius="23,23,0,0">
                    <Grid MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <Image Source="/Assets/logo.png" Width="30" Height="30" Margin="18,0,0,0"/>
                    
                    <TextBlock Grid.Column="1"
                               Text="Setup Assistant"
                               Foreground="#F2FFFFFF"
                               FontSize="14"
                               FontWeight="Bold"
                               FontFamily="{StaticResource SFProDisplay}"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0"/>
                    
                    <Button Grid.Column="2"
                            Width="52"
                            Height="58"
                            Background="Transparent"
                            Foreground="#999999"
                            BorderThickness="0"
                            FontSize="16"
                            Cursor="Hand"
                            Click="CloseButton_Click">
                        <Button.Content>
                            <TextBlock x:Name="CloseIcon" Text="✕" RenderTransformOrigin="0.5,0.5">
                                <TextBlock.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </TextBlock.RenderTransform>
                            </TextBlock>
                        </Button.Content>
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="Transparent">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Foreground" Value="#FF3B30"/>
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Button.Content).(TextBlock.RenderTransform).(ScaleTransform.ScaleX)"
                                                                   To="1.15"
                                                                   Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Button.Content).(TextBlock.RenderTransform).(ScaleTransform.ScaleY)"
                                                                   To="1.15"
                                                                   Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                        <Trigger.ExitActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Button.Content).(TextBlock.RenderTransform).(ScaleTransform.ScaleX)"
                                                                   To="1"
                                                                   Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                    <DoubleAnimation Storyboard.TargetProperty="(Button.Content).(TextBlock.RenderTransform).(ScaleTransform.ScaleY)"
                                                                   To="1"
                                                                   Duration="0:0:0.15">
                                                        <DoubleAnimation.EasingFunction>
                                                            <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                                        </DoubleAnimation.EasingFunction>
                                                    </DoubleAnimation>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.ExitActions>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter Property="Foreground" Value="#FF3B30"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                    </Grid>
                </Border>
                
                <!-- Content area -->
                <Border Grid.Row="1" Background="#0A0A0C">
                    <Grid Margin="28,22">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="140" MaxWidth="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="20" Background="#101014" BorderBrush="#18FFFFFF" BorderThickness="1" Padding="16" Margin="0,0,24,0">
                        <StackPanel>
                            <Image Source="/Assets/logo.png" Width="68" Height="68" HorizontalAlignment="Left" Margin="0,0,0,18"/>
                            <TextBlock Text="V-Notch" FontSize="18" FontWeight="Bold" Foreground="White" FontFamily="{StaticResource SFProDisplay}"/>
                            <TextBlock Text="Dynamic Island for Windows" FontSize="11.5" Foreground="#99FFFFFF" TextWrapping="Wrap" LineHeight="16" Margin="0,4,0,18"/>
                            <StackPanel>
                                <TextBlock x:Name="Step1Text" Text="01  Language" Foreground="#FFFFFFFF" FontSize="11.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="Step2Text" Text="02  Welcome" Foreground="#88FFFFFF" FontSize="11.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="Step3Text" Text="03  About" Foreground="#88FFFFFF" FontSize="11.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="Step4Text" Text="04  Location" Foreground="#88FFFFFF" FontSize="11.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="Step5Text" Text="05  Startup" Foreground="#88FFFFFF" FontSize="11.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="Step6Text" Text="06  Install" Foreground="#88FFFFFF" FontSize="11.5" Margin="0,0,0,8"/>
                                <TextBlock x:Name="Step7Text" Text="07  Finish" Foreground="#88FFFFFF" FontSize="11.5"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                                  Padding="0" Background="Transparent" BorderThickness="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        
                        <Image x:Name="IconContainer" Grid.Row="0" Source="/Assets/logo.png" Width="52" Height="52" HorizontalAlignment="Left" Margin="0,0,0,18" Opacity="0">
                            <Image.RenderTransform>
                                <TranslateTransform x:Name="IconTranslate" Y="8"/>
                            </Image.RenderTransform>
                        </Image>
                        
                        <TextBlock x:Name="HeadlineText" Grid.Row="1" Text="Welcome to V-Notch" FontSize="34" FontWeight="Bold" Foreground="White" FontFamily="{StaticResource SFProDisplay}" Margin="0,0,0,12" TextWrapping="Wrap" Opacity="0">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="HeadlineTranslate" Y="8"/>
                            </TextBlock.RenderTransform>
                        </TextBlock>
                        
                        <TextBlock x:Name="BodyText" Grid.Row="2" FontSize="14" Foreground="#CCFFFFFF" FontFamily="{StaticResource SFProDisplay}" LineHeight="23" TextWrapping="Wrap" Opacity="0">
                            <TextBlock.RenderTransform>
                                <TranslateTransform x:Name="BodyTranslate" Y="8"/>
                            </TextBlock.RenderTransform>
                            <Run Text="Hey there! Thanks for choosing V-Notch."/>
                            <LineBreak/><LineBreak/>
                            <Run Text="We're about to set up a sleek little notch at the top of your screen — it handles your music, battery, calendar, file shelf, and more. Think of it as a tiny command center that stays out of your way until you need it."/>
                            <LineBreak/><LineBreak/>
                            <Run Text="This will only take a minute. Let's get started!" FontWeight="Bold"/>
                        </TextBlock>
                        
                        <ContentPresenter x:Name="ContentPresenter" Grid.Row="0" Grid.RowSpan="3" Visibility="Collapsed"/>
                    </Grid>
                    </ScrollViewer>
                    </Grid>
                </Border>
                
                <!-- Button panel -->
                <Border Grid.Row="2"
                        Background="#08080A"
                        BorderBrush="#22FFFFFF"
                        BorderThickness="0,1,0,0"
                        CornerRadius="0,0,24,24"
                        Padding="24,16">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ButtonTranslate" Y="8"/>
                    </Border.RenderTransform>
                    <StackPanel x:Name="ButtonPanel" Orientation="Horizontal" HorizontalAlignment="Right" Opacity="0">
                        <Button x:Name="CancelButton"
                                Content="Cancel"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,0"
                                Click="CancelButton_Click"/>
                        <Button x:Name="BackButton"
                                Content="Back"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,0"
                                Click="BackButton_Click"
                                Visibility="Collapsed"/>
                        <Button x:Name="NextButton"
                                Content="Continue"
                                Style="{StaticResource SetupButtonStyle}"
                                Click="NextButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
