<Window x:Class="VNotch.IntroducingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        Title="Introducing Liquid Glass"
        Width="860" Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <FontFamily x:Key="SettingsFont">pack://application:,,,/Fonts/#SF Pro Display</FontFamily>
        
        <SolidColorBrush x:Key="PanelBg" Color="#F4020202"/>
        <SolidColorBrush x:Key="MutedText" Color="#8C959E"/>
        
        <LinearGradientBrush x:Key="WindowGlow" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#090909" Offset="0"/>
            <GradientStop Color="#030303" Offset="0.55"/>
            <GradientStop Color="#000000" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>
    </Window.Resources>

    <Border x:Name="MainShell"
            Margin="18"
            CornerRadius="24"
            Background="{StaticResource WindowGlow}"
            BorderBrush="#18FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            Opacity="0"
            Focusable="True"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ShellScale" ScaleX="0.95" ScaleY="0.95"/>
                <TranslateTransform x:Name="ShellTranslate" Y="15"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid x:Name="ShellContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border x:Name="IntroHeader"
                    Grid.Row="0"
                    Padding="22,20,18,18"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TitleText" Text="INTRODUCING"
                               FontSize="15"
                               FontWeight="Bold"
                               Foreground="#F8FBFF"
                               VerticalAlignment="Center"/>

                    <!-- Close Button -->
                    <Button Grid.Column="1"
                            x:Name="CloseButton"
                            Width="30" Height="30"
                            Cursor="Hand"
                            Click="CloseButton_Click"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" CornerRadius="15" x:Name="bg">
                                    <TextBlock Text="✕" FontSize="14" Foreground="#88ffffff" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="txt"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bg" Property="Background" Value="#22ffffff"/>
                                        <Setter TargetName="txt" Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- CONTENT BODY -->
            <Grid Grid.Row="1" Margin="30,20,30,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- GIF Image -->
                <Border Grid.Row="0" Width="580" Height="300" CornerRadius="16" ClipToBounds="True" BorderBrush="#12ffffff" BorderThickness="1" Background="#05ffffff" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Image x:Name="IntroGif"
                           Stretch="Uniform"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
                </Border>

                <!-- Headline -->
                <TextBlock Grid.Row="1"
                           x:Name="HeadlineText"
                           Text="Liquid Glass Theme"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,20,0,10"/>

                <!-- Body Text -->
                <TextBlock Grid.Row="2"
                           x:Name="BodyText"
                           Text="A new skin that turns the notch into liquid glass — refracting the desktop behind it in real time, with soft chromatic edges, depth, and a frosted blur."
                           FontSize="14"
                           FontWeight="Medium"
                           Foreground="{StaticResource MutedText}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           MaxWidth="600"
                           LineHeight="20"/>
            </Grid>

            <!-- FOOTER -->
            <Border Grid.Row="2"
                    Padding="22,18,22,22"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <!-- Close button in center -->
                    <Button x:Name="GotItButton"
                            HorizontalAlignment="Center"
                            MinWidth="120"
                            Height="38"
                            Cursor="Hand"
                            Click="GotItButton_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="White" CornerRadius="19" x:Name="border">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <ContentPresenter.Resources>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontSize" Value="13.5"/>
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
                                            </Style>
                                        </ContentPresenter.Resources>
                                    </ContentPresenter>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#C0C0C0"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
