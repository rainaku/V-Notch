<Window x:Class="VNotch.SpotifyLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Connect Spotify"
        Width="520"
        Height="700"
        MinWidth="460"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#080808"
        Foreground="White"
        Closed="Window_Closed">
    <Window.Resources>
        <FontFamily x:Key="SpotifyLoginFont">pack://application:,,,/Fonts/#SF Pro Display, Nirmala UI, Segoe UI</FontFamily>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="{StaticResource SpotifyLoginFont}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontFamily" Value="{StaticResource SpotifyLoginFont}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#202020"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#363636"/>
        </Style>
    </Window.Resources>

    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HeadingText"
                   Text="Connect Spotify"
                   FontSize="20"
                   FontWeight="Bold"/>
        <TextBlock x:Name="HintText"
                   Grid.Row="1"
                   Text="Sign in once. V-Notch will detect the Spotify session automatically."
                   Foreground="#9CA3AF"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Margin="0,5,0,12"/>

        <Border Grid.Row="2"
                Background="#111111"
                BorderBrush="#2A2A2A"
                BorderThickness="1"
                CornerRadius="10"
                ClipToBounds="True">
            <wv2:WebView2 x:Name="SpotifyWebView"/>
        </Border>

        <Grid Grid.Row="3" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="StatusText"
                       Text="Opening Spotify…"
                       Foreground="#9CA3AF"
                       FontSize="11"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="0,0,12,0"/>
            <Button x:Name="CancelButton"
                    Grid.Column="1"
                    Content="Cancel"
                    Click="CancelButton_Click"/>
        </Grid>
    </Grid>
</Window>
