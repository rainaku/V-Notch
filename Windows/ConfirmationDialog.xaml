<Window x:Class="VNotch.Windows.ConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm Action" 
        Height="200" 
        Width="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Topmost="True">
    
    <Window.Resources>
        <Style x:Key="DialogButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A2A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#404040"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#353535"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#252525"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ConfirmButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#0066FF"/>
            <Setter Property="BorderBrush" Value="#0055DD"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#0077FF"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#0055DD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DialogButton}">
            <Setter Property="Background" Value="#DC3545"/>
            <Setter Property="BorderBrush" Value="#BB2D3B"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E84855"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#BB2D3B"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#1E1E1E" 
            BorderBrush="#404040" 
            BorderThickness="1" 
            CornerRadius="10"
            Padding="0">
        
        <Border.Effect>
            <DropShadowEffect Color="Black" Direction="270" ShadowDepth="2" Opacity="0.6" BlurRadius="15"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" 
                    Background="#252525" 
                    CornerRadius="10,10,0,0"
                    Padding="16,12"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock x:Name="TitleText"
                           Text="Confirm Action"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="White"/>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" Margin="20,20,20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <Viewbox x:Name="IconViewbox" 
                         Grid.Column="0" 
                         Width="32" 
                         Height="32" 
                         Margin="0,0,12,0"
                         VerticalAlignment="Top">
                    <Canvas Width="24" Height="24">
                        <!-- Warning Icon (default) -->
                        <Path x:Name="WarningIcon" 
                              Data="M12,2 L22,20 L2,20 Z M12,8 L12,14 M12,16 L12,18"
                              Stroke="#FFA500" 
                              StrokeThickness="2" 
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="None"/>
                    </Canvas>
                </Viewbox>

                <!-- Message -->
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="MessageText"
                               Text="Are you sure you want to proceed?"
                               FontSize="13"
                               Foreground="#E0E0E0"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                    
                    <TextBlock x:Name="DetailText"
                               Margin="0,8,0,0"
                               FontSize="12"
                               Foreground="#999999"
                               TextWrapping="Wrap"
                               LineHeight="18"
                               Visibility="Collapsed"/>
                </StackPanel>
            </Grid>

            <!-- Buttons -->
            <Border Grid.Row="2" 
                    Background="#252525" 
                    BorderBrush="#333333" 
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10"
                    Padding="16,12">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton"
                            Content="Cancel"
                            Style="{StaticResource DialogButton}"
                            Click="CancelButton_Click"
                            IsCancel="True"
                            Margin="0,0,8,0"
                            MinWidth="80"/>
                    
                    <Button x:Name="ConfirmButton"
                            Content="Confirm"
                            Style="{StaticResource ConfirmButton}"
                            Click="ConfirmButton_Click"
                            IsDefault="True"
                            MinWidth="80"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
