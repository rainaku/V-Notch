                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock x:Name="RequestFeatureLabel" Text="Request a feature"
                                                   Style="{StaticResource SettingTitleText}"/>
                                        <TextBlock x:Name="RequestFeatureHint" Text="I'm currently out of ideas. If you have any, don't hesitate to request!"
                                                   Style="{StaticResource SettingHintText}"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1"
                                            Width="40"
                                            Height="40"
                                            Click="RequestFeature_Click"
                                            ToolTip="Request Feature on GitHub"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Viewbox Width="36" Height="36" Stretch="Uniform">
                                            <Path Data="M31 8.5c0 0-2.53 5.333-3.215 8.062-0.896 3.57 0.13 6.268-1.172 9.73-2.25 4.060-2.402 4.717-10.613 4.708-3.009-0.003-11.626-2.297-11.626-2.297-1.188-0.305-3.373-0.125-3.373-1.453s1.554-2.296 2.936-2.3l5.439 0.478c1.322-0.083 2.705-0.856 2.747-2.585-0.022-2.558-0.275-4.522-1.573-6.6l-5.042-7.867c-0.301-0.626-0.373-1.694 0.499-2.171s1.862 0.232 2.2 0.849l5.631 7.66c0.602 0.559 1.671 0.667 1.58-0.524l-2.487-11.401c-0.155-0.81 0.256-1.791 1.194-1.791 1.231 0 1.987 0.47 1.963 1.213l2.734 11.249c0.214 0.547 0.972 0.475 1.176-0.031l0.779-10.939c0.040-0.349 0.495-0.957 1.369-0.831s1.377 1.063 1.285 1.424l-0.253 10.809c0.177 0.958 0.93 1.098 1.517 0.563l3.827-6.843c0.232-0.574 1.143-0.693 1.67-0.466 0.491 0.32 0.81 0.748 0.81 1.351v0z"
                                                  Fill="White"/>
                                        </Viewbox>
                                    </Button>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                    <Border x:Name="DisplayCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="DisplayCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock x:Name="DisplayHeader" Text="DISPLAY" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock x:Name="MonitorLabel" Text="Active Monitor" Style="{StaticResource SettingTitleText}"/>
                                    <TextBlock x:Name="MonitorHint" Text="Choose which screen anchors the notch."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,6,0,0"/>
                                    <ComboBox x:Name="MonitorCombo"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SystemCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="SystemCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock x:Name="SystemHeader" Text="SYSTEM" Style="{StaticResource SectionHeader}"/>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="AutoStartCheck" x:Uid="autoStart" Content="Start with Windows"/>
                                    <TextBlock x:Name="AutoStartHint" Text="Launch automatically when you sign in."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="HideOnExclusiveFullscreenCheck" x:Uid="hideExclusiveFs" Content="Hide on exclusive fullscreen"/>
                                    <TextBlock x:Name="HideOnExclusiveFullscreenHint" Text="Hide the notch when a true fullscreen app is detected."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="HideOnWindowedFullscreenCheck" x:Uid="hideWindowedFs" Content="Hide on windowed fullscreen"/>
                                    <TextBlock x:Name="HideOnWindowedFullscreenHint" Text="Hide the notch when a borderless windowed fullscreen app is detected."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="MusicNotifyCheck" x:Uid="musicNotify" Content="Show music notifications"/>
                                    <TextBlock x:Name="MusicNotifyHint" Text="Keep the media widget responsive to playback changes."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <CheckBox x:Name="SystemNotifyCheck" x:Uid="systemNotify" Content="Show system notifications"/>
                                    <TextBlock x:Name="SystemNotifyHint" Text="Allow the notch to surface device and system signals."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <CheckBox x:Name="ShelfUnlockCheck" x:Uid="shelfUnlock" Content="Unlock shelf upload limit"/>
                                    <TextBlock x:Name="ShelfUnlockHint" Text="Remove the 30-file safety limit on the shelf."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock x:Name="LanguageLabel" Text="Language" Style="{StaticResource SettingTitleText}"/>
                                    <TextBlock x:Name="LanguageHint" Text="Choose the display language for V-Notch."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,6,0,8"/>
                                    <ComboBox x:Name="LanguageCombo" SelectionChanged="LanguageCombo_SelectionChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="AdvancedCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="AdvancedCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock x:Name="AdvancedHeader" Text="ADVANCED" Style="{StaticResource SectionHeader}"/>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="YouTubeApiCheck" x:Uid="youtubeApi" Content="Use YouTube Data API"
                                              Checked="YouTubeApiCheck_Changed" Unchecked="YouTubeApiCheck_Changed"/>
                                    <TextBlock x:Name="YouTubeApiHint" Text="Improve thumbnail accuracy with your own YouTube API key."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border x:Name="YouTubeApiKeyRow" Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4" Visibility="Collapsed">
                                <StackPanel>
                                    <TextBlock x:Name="YouTubeApiKeyLabel" Text="API Key" Style="{StaticResource SettingTitleText}"/>
                                    <TextBlock x:Name="YouTubeApiKeyHint" Text="Paste your YouTube Data API v3 key from Google Cloud Console."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,6,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>
                                        <PasswordBox x:Name="YouTubeApiKeyPasswordBox"
                                                 Height="40"
                                                 Padding="12,10"
                                                 FontSize="12"
                                                 FontFamily="{StaticResource SettingsFont}"
                                                 Background="#0F0F0F"
                                                 Foreground="#E0E0E0"
                                                 BorderBrush="#2A2A2A"
                                                 BorderThickness="1"
                                                 CaretBrush="#FFFFFF"
                                                 VerticalContentAlignment="Center"
                                                 PasswordChar="●"
                                                 PasswordChanged="YouTubeApiKeyPasswordBox_PasswordChanged">
                                            <PasswordBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </PasswordBox.Resources>
                                        </PasswordBox>
                                        <TextBox x:Name="YouTubeApiKeyTextBox"
                                                 Height="40"
                                                 Padding="12,10"
                                                 FontSize="12"
                                                 FontFamily="{StaticResource SettingsFont}"
                                                 Background="#0F0F0F"
                                                 Foreground="#E0E0E0"
                                                 BorderBrush="#2A2A2A"
                                                 BorderThickness="1"
                                                 CaretBrush="#FFFFFF"
                                                 VerticalContentAlignment="Center"
                                                 Visibility="Collapsed"
                                                 TextChanged="YouTubeApiKeyTextBox_TextChanged">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>
                                        <Button x:Name="ToggleKeyVisibilityButton"
                                                Grid.Column="1"
                                                Width="36" Height="36"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Cursor="Hand"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Center"
                                                Click="ToggleKeyVisibility_Click"
                                                ToolTip="Show/Hide key">
                                            <Grid Width="20" Height="20">
                                                <!-- Eye Open icon -->
                                                <Canvas x:Name="EyeOpenIcon" Width="20" Height="20" Opacity="1">
                                                    <Path Fill="#CCCCCC" Data="M10 4C5.6 4 1.9 6.7 0.2 10.5C0.1 10.8 0.1 11.2 0.2 11.5C1.9 15.3 5.6 18 10 18C14.4 18 18.1 15.3 19.8 11.5C19.9 11.2 19.9 10.8 19.8 10.5C18.1 6.7 14.4 4 10 4ZM10 15.5C7.5 15.5 5.5 13.5 5.5 11C5.5 8.5 7.5 6.5 10 6.5C12.5 6.5 14.5 8.5 14.5 11C14.5 13.5 12.5 15.5 10 15.5ZM10 8.5C8.6 8.5 7.5 9.6 7.5 11C7.5 12.4 8.6 13.5 10 13.5C11.4 13.5 12.5 12.4 12.5 11C12.5 9.6 11.4 8.5 10 8.5Z"/>
                                                </Canvas>
                                                <!-- Eye Closed icon -->
                                                <Canvas x:Name="EyeClosedIcon" Width="20" Height="20" Opacity="0">
                                                    <Path Data="M2.5 2.5L17.5 17.5M8.1 8.2C7.7 8.6 7.5 9.3 7.5 10C7.5 11.4 8.6 12.5 10 12.5C10.7 12.5 11.4 12.3 11.8 11.8M14.1 14.2C12.9 15.1 11.5 15.5 10 15.5C5.6 15.5 1.9 12.8 0.2 9C0.9 7.5 1.9 6.2 3.2 5.2M7.5 4.5C8.3 4.2 9.1 4 10 4C14.4 4 18.1 6.7 19.8 10.5C19.4 11.4 18.9 12.2 18.3 12.9" Stroke="#CCCCCC" StrokeThickness="1.5" Fill="Transparent"/>
                                                </Canvas>
                                            </Grid>
                                        </Button>
                                    </Grid>
                                    <TextBlock x:Name="YouTubeApiKeyStatus" 
                                               Text=""
                                               FontSize="11"
                                               Foreground="#6B7280"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border x:Name="FooterBar"
                    Grid.Row="2"
                    Background="#D1050505"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0,0,24,24"
                    Padding="18"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="FooterTranslate" Y="10"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ResetButton" Grid.Column="0"
                            Margin="0,0,8,0"
                            Content="Reset"
                            Click="Reset_Click"/>
                    <Button x:Name="ApplyButton" Grid.Column="1"
                            Margin="4,0"
                            Content="Apply"
                            Click="Apply_Click"/>
                    <Button x:Name="SaveButton" Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Save"
                            Style="{StaticResource PrimaryButton}"
                            Click="Save_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
