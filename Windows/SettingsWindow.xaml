                                        <TranslateTransform x:Name="SearchingCardTranslate" Y="12"/>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock x:Name="SearchingHeader" Text="SEARCHING" Style="{StaticResource SectionHeader}"/>
