                                        <Run x:Name="WidthValue" Text="360"/><Run Text=" px"/>
                                    </TextBlock>
                                    <TextBlock x:Name="WidthHint" Visibility="Collapsed"/>
                                    <controls:ElasticSlider x:Name="WidthSlider"
                                            Label="Width" Unit=" px"
                                            Description="How wide the compact notch should sit on screen."
                                            Minimum="100"
                                            Maximum="400"
                                            Value="200"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="WidthSlider_ValueChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <TextBlock x:Name="HeightLabel" Text="Height" Style="{StaticResource SettingTitleText}" Visibility="Collapsed"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource ValueText}" Visibility="Collapsed">
                                        <Run x:Name="HeightValue" Text="32"/><Run Text=" px"/>
                                    </TextBlock>
                                    <TextBlock x:Name="HeightHint" Visibility="Collapsed"/>
                                    <controls:ElasticSlider x:Name="HeightSlider"
                                            Label="Height" Unit=" px"
                                            Description="Controls the compact profile thickness."
                                            Minimum="20"
                                            Maximum="50"
                                            Value="32"
                                            TickFrequency="2"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="HeightSlider_ValueChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <TextBlock x:Name="RadiusLabel" Text="Corner Radius" Style="{StaticResource SettingTitleText}" Visibility="Collapsed"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource ValueText}" Visibility="Collapsed">
                                        <Run x:Name="RadiusValue" Text="16"/><Run Text=" px"/>
                                    </TextBlock>
                                    <TextBlock x:Name="RadiusHint" Visibility="Collapsed"/>
                                    <controls:ElasticSlider x:Name="RadiusSlider"
                                            Label="Corner Radius" Unit=" px"
                                            Description="Sharper for utility, softer for an island-like feel."
                                            Minimum="0"
                                            Maximum="30"
                                            Value="16"
                                            TickFrequency="2"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="RadiusSlider_ValueChanged"/>

                                    <CheckBox x:Name="DynamicIslandModeCheck"
                                              x:Uid="dynamicIslandMode"
                                              Content="Dynamic Island mode"
                                              Margin="0,14,0,0"
