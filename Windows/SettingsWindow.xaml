                                <StackPanel>
                                    <TextBlock x:Name="BlurLabel" Text="Blur Brightness" Style="{StaticResource SettingTitleText}" Visibility="Collapsed"/>
                                    <TextBlock Grid.Column="1" Style="{StaticResource ValueText}" Visibility="Collapsed">
                                        <Run x:Name="BlurBrightnessValue" Text="140"/><Run Text=" %"/>
                                    </TextBlock>
                                    <TextBlock x:Name="BlurHint" Visibility="Collapsed"/>
                                    <controls:ElasticSlider x:Name="BlurBrightnessSlider"
                                            Label="Blur Brightness" Unit="%"
                                            Description="Brighten the expanded media blur without changing the notch body opacity."
                                            Minimum="100"
                                            Maximum="200"
                                            Value="140"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="BlurBrightnessSlider_ValueChanged"/>

                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

