                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock x:Name="ClearCacheLabel" Text="Clear cache"
                                                               Style="{StaticResource SettingTitleText}"/>
                                                    <TextBlock x:Name="ClearCacheHint" Text="Remove cached data and logs. Settings are preserved."
                                                               Style="{StaticResource SettingHintText}"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Width="40"
                                                        Height="40"
                                                        Click="ClearCache_Click"
                                                        ToolTip="Clear Cache"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Viewbox Width="36" Height="36" Stretch="Uniform">
                                                        <Path Data="M410.886,43.93H301.533C299.778,19.793,280.576,0.093,256.005,0c-24.598,0.093-43.8,19.793-45.556,43.93H101.115c-22.787,0-41.407,18.628-41.407,41.398v1.792v15.543v14.822c0,5.692,4.648,10.35,10.34,10.35h0.674l23.859,342.87C96.152,493.408,116.075,512,138.853,512h75.745c22.76,0,60.027,0,82.814,0h75.726c22.769,0,42.701-18.592,44.281-41.296l23.84-342.87h0.675c5.702,0,10.358-4.658,10.358-10.35v-14.822V87.12v-1.792C452.292,62.558,433.654,43.93,410.886,43.93z"
                                                              Fill="White"/>
                                                    </Viewbox>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- FOOTER -->
            <Border x:Name="FooterBar"
                    Grid.Row="2"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="0"
                    CornerRadius="0,0,24,24"
                    Padding="18"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="FooterTranslate" Y="10"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ResetButton" Grid.Column="0"
                            Margin="0,0,8,0"
                            Content="Reset"
                            Click="Reset_Click"/>
                    <Button x:Name="ApplyButton" Grid.Column="1"
                            Margin="4,0"
                            Content="Apply"
                            Click="Apply_Click"/>
                    <Button x:Name="SaveButton" Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Save"
                            Style="{StaticResource PrimaryButton}"
                            Click="Save_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>