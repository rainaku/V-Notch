                                                    <Run x:Name="HoverDelayValue" Text="100"/><Run Text=" ms"/>
                                                </TextBlock>
                                                <TextBlock x:Name="ExpandDelayHint" Visibility="Collapsed"/>
                                                <controls:ElasticSlider x:Name="HoverDelaySlider"
                                                        Label="Expand Delay" Unit=" ms"
