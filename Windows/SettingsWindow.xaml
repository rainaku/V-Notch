                                    </TextBlock>
                                    <TextBlock x:Name="OpacityHint" Visibility="Collapsed"/>
                                    <controls:ElasticSlider x:Name="OpacitySlider"
                                            Label="Opacity" Unit="%"
                                            Description="Blend the notch into the desktop or keep it crisp and solid."
                                            Minimum="50"
                                            Maximum="100"
                                            Value="100"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="OpacitySlider_ValueChanged"/>
                                </StackPanel>
                            </Border>

