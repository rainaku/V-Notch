                                                        Minimum="0"
                                                        Maximum="500"
                                                        Value="100"
                                                        TickFrequency="50"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="HoverDelaySlider_ValueChanged"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="DisableMouseLeaveAutoCloseCheck" x:Uid="disableMouseLeaveAutoClose" Content="Click to close (no auto-close)"/>
