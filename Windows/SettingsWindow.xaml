<Window x:Class="VNotch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:VNotch.Controls"
        Title="V-Notch Settings"
        Width="860"
        Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded"
        FocusManager.FocusedElement="{Binding ElementName=MainShell}">

    <Window.Resources>
        <FontFamily x:Key="SettingsFont">pack://application:,,,/Fonts/#SF Pro Display</FontFamily>
        <SolidColorBrush x:Key="PanelBg" Color="#F4020202"/>
        <SolidColorBrush x:Key="CardBg" Color="#F0080808"/>
        <SolidColorBrush x:Key="CardBorder" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="MutedText" Color="#8C959E"/>
        <SolidColorBrush x:Key="SoftText" Color="#D8DEE5"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="AccentBrushStrong" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TrackBg" Color="#262626"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#141414"/>
        <SolidColorBrush x:Key="SurfaceBrushHover" Color="#1B1B1B"/>
        <SolidColorBrush x:Key="NavItemBg" Color="Transparent"/>
        <SolidColorBrush x:Key="NavItemActiveBg" Color="#1AFFFFFF"/>

        <LinearGradientBrush x:Key="WindowGlow" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#090909" Offset="0"/>
            <GradientStop Color="#030303" Offset="0.55"/>
            <GradientStop Color="#000000" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7C7C7C"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="#0AFFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18,14"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SettingHintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F4F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SliderLabelGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="SettingRowBorder" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Padding" Value="0,8"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="NavButton" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid MinHeight="26" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter Grid.Column="0"
                                              VerticalAlignment="Center"
                                              Margin="0,3,12,3"
                                              RecognizesAccessKey="True"/>

                            <Border x:Name="SwitchTrack"
                                    Grid.Column="1"
                                    Width="42"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="#000000"
                                    BorderBrush="Transparent"
                                    BorderThickness="0"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                                <Grid>
                                    <Ellipse x:Name="SwitchThumb"
                                             Width="24"
                                             Height="24"
                                             Fill="White"
                                             Margin="0,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="5" ShadowDepth="2"
                                                              Opacity="0.25" Color="Black" Direction="270"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#1A1A1A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#00FF00"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="18,0,0,0"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                From="0,0,0,0"
                                                                To="18,0,0,0"
                                                                Duration="0:0:0.4"
                                                                Timeline.DesiredFrameRate="144">
                                                <ThicknessAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            From="#000000"
                                                            To="#00FF00"
                                                            Duration="0:0:0.4"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="0,0,0,0"
                                                                Duration="0:0:0.4"
                                                                Timeline.DesiredFrameRate="144">
                                                <ThicknessAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.4"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#000000"
                                                            Duration="0:0:0.4"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsChecked" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#33FF33"/>
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="controls:ElasticSlider">
            <Setter Property="Margin" Value="0,2,0,4"/>
            <Setter Property="Height" Value="Auto"/>
            <Setter Property="MinHeight" Value="62"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="controls:ElasticSlider">
                        <StackPanel>
                            <TextBlock x:Name="PART_Label"
                                       Margin="2,0,0,3"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       FontFamily="{StaticResource SFProDisplay}"
                                       IsHitTestVisible="False"/>
                            <TextBlock x:Name="PART_Description"
                                       Margin="2,0,0,7"
                                       FontSize="11.5"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource MutedText}"
                                       TextWrapping="Wrap"
                                       FontFamily="{StaticResource SettingsFont}"
                                       IsHitTestVisible="False"/>
                            <Border x:Name="PART_Root"
                                    Height="38"
                                    CornerRadius="10"
                                    Background="#14FFFFFF"
                                    SnapsToDevicePixels="True"
                                    ClipToBounds="True">
                                <Grid>
                                    <Border x:Name="PART_Fill"
                                            HorizontalAlignment="Left"
                                            CornerRadius="10"
                                            Background="#1EFFFFFF"
                                            Width="0"/>
                                    <Canvas x:Name="PART_Ticks"
                                            IsHitTestVisible="False"/>
                                    <Canvas IsHitTestVisible="False">
                                        <Rectangle x:Name="PART_Indicator"
                                                   Width="3"
                                                   Height="18"
                                                   RadiusX="1.5"
                                                   RadiusY="1.5"
                                                   Fill="White"
                                                   Canvas.Top="10"
                                                   Canvas.Left="0">
                                            <Rectangle.Effect>
                                                <DropShadowEffect BlurRadius="5" ShadowDepth="0"
                                                                  Opacity="0.45" Color="White"/>
                                            </Rectangle.Effect>
                                        </Rectangle>
                                    </Canvas>
                                    <TextBlock x:Name="PART_Value"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right"
                                               Margin="0,0,12,0"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#DDFFFFFF"
                                               FontFamily="{StaticResource SFProDisplay}"
                                               IsHitTestVisible="False"/>
                                    <Track x:Name="PART_Track" Visibility="Hidden"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F5F8FB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#22FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="#F5F8FB"/>
            <Setter Property="BorderBrush" Value="#304051"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="#2A2A2A"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14,0"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                                            </Border.RenderTransform>
                                            <Grid>
                                                <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  TextElement.Foreground="#F5F8FB"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="#C8D1DD"
                                                      StrokeThickness="1.6"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4C4C4C"/>
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{StaticResource SurfaceBrushHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   StaysOpen="False">
                                <Border x:Name="DropdownBorder"
                                        Background="#0F0F12"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Margin="0,4,0,0"
                                        Padding="0,4"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        RenderTransformOrigin="0.5,0"
                                        Effect="{x:Null}">
                                    <Border.RenderTransform>
                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    </Border.RenderTransform>
                                    <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Margin="0,8,4,8">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0"/></Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0"/></Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#505050" CornerRadius="4" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="#F7FAFD"/>
            <Setter Property="BorderBrush" Value="#2B2B2B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource SurfaceBrushHover}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#484848"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#202020"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.988" ScaleY="0.988"/>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F3F6FA"/>
            <Setter Property="Foreground" Value="#11161D"/>
            <Setter Property="BorderBrush" Value="#F3F6FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DDE5EF"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.988" ScaleY="0.988"/>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainShell"
            Margin="18"
            CornerRadius="24"
            Background="{StaticResource WindowGlow}"
            BorderBrush="#18FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            Opacity="0"
            Focusable="True"
            PreviewMouseLeftButtonDown="WindowSurface_PreviewMouseLeftButtonDown"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ShellScale" ScaleX="0.985" ScaleY="0.985"/>
                <TranslateTransform x:Name="ShellTranslate" Y="8"/>
            </TransformGroup>
        </Border.RenderTransform>

        <Grid x:Name="ShellContent">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border x:Name="SettingsHeader"
                    Grid.Row="0"
                    Padding="22,20,18,18"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="HeaderTranslate" Y="10"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="56"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="SettingsTitleText" Text="SETTINGS"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="#F8FBFF"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="SettingsSubtitleText" Visibility="Collapsed"/>
                        <!-- Search Box -->
                        <Border Background="#0FFFFFFF" CornerRadius="10" Padding="10,0" Margin="16,0,0,0"
                                Height="36" MinWidth="220" VerticalAlignment="Center"
                                BorderBrush="#14FFFFFF" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" FontSize="13"
                                           Foreground="#666666" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBox x:Name="SettingsSearchBox" Grid.Column="1"
                                         Background="Transparent" BorderThickness="0"
                                         Foreground="White" FontSize="13" FontWeight="Bold"
                                         FontFamily="{StaticResource SettingsFont}"
                                         VerticalContentAlignment="Center"
                                         CaretBrush="White"
                                         TextChanged="SettingsSearchBox_TextChanged"
                                         GotFocus="SettingsSearchBox_GotFocus"
                                         LostFocus="SettingsSearchBox_LostFocus"/>
                                <TextBlock x:Name="SearchPlaceholder" Grid.Column="1"
                                           Text="Search settings..."
                                           FontSize="13" FontWeight="Bold"
                                           Foreground="#555555"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           FontFamily="{StaticResource SettingsFont}"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- Social Links -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button x:Name="SocialWebsite" Width="34" Height="34" MinWidth="0" Padding="0"
                                BorderThickness="0" Background="Transparent"
                                Cursor="Hand" Click="SocialLink_Website_Click"
                                ToolTip="Website" Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <TranslateTransform x:Name="SocialWebsiteTranslate" Y="6"/>
                            </Button.RenderTransform>
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="16" Height="16">
                                    <Path Stroke="#8C959E" StrokeThickness="1.2" Fill="Transparent" Data="M8,1 A7,7 0 1,0 8,15 A7,7 0 1,0 8,1 Z"/>
                                    <Path Stroke="#8C959E" StrokeThickness="1.2" Fill="Transparent" Data="M8,1 C5.5,1 4,4.5 4,8 C4,11.5 5.5,15 8,15 C10.5,15 12,11.5 12,8 C12,4.5 10.5,1 8,1 Z"/>
                                    <Path Stroke="#8C959E" StrokeThickness="1.2" Fill="Transparent" Data="M1.5,5.5 L14.5,5.5"/>
                                    <Path Stroke="#8C959E" StrokeThickness="1.2" Fill="Transparent" Data="M1.5,10.5 L14.5,10.5"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                        <Button x:Name="SocialGitHub" Width="34" Height="34" MinWidth="0" Padding="0"
                                BorderThickness="0" Background="Transparent"
                                Cursor="Hand" Click="SocialLink_GitHub_Click"
                                ToolTip="GitHub Repository" Opacity="0"
                                RenderTransformOrigin="0.5,0.5">
                            <Button.RenderTransform>
                                <TranslateTransform x:Name="SocialGitHubTranslate" Y="6"/>
                            </Button.RenderTransform>
