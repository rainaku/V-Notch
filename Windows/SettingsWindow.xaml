                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ===== DEVICES PANEL ===== -->
                            <StackPanel x:Name="PanelDevices" Visibility="Collapsed">
                                <Border x:Name="DisplayCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="DisplayCardTranslate" Y="12"/>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock x:Name="DisplayHeader" Text="DEVICES" Style="{StaticResource SectionHeader}"/>
                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock x:Name="MonitorLabel" Text="Active Monitor" Style="{StaticResource SettingTitleText}"/>
                                                <TextBlock x:Name="MonitorHint" Text="Choose which screen anchors the notch."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,6,0,0"/>
                                                <ComboBox x:Name="MonitorCombo"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock x:Name="CameraLabel" Text="Camera" Style="{StaticResource SettingTitleText}"/>
                                                <TextBlock x:Name="CameraHint" Text="Choose which camera device to use for the camera view."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,6,0,0"/>
                                                <ComboBox x:Name="CameraCombo" SelectionChanged="CameraCombo_SelectionChanged"/>
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock x:Name="VisualizerAudioLabel" Text="Music Visualizer Speaker" Style="{StaticResource SettingTitleText}"/>
                                                <TextBlock x:Name="VisualizerAudioHint" Text="Choose which speaker drives the music visualizer."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,6,0,0"/>
                                                <ComboBox x:Name="VisualizerAudioCombo" SelectionChanged="VisualizerAudioCombo_SelectionChanged"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ===== SYSTEM PANEL ===== -->
                            <StackPanel x:Name="PanelSystem" Visibility="Collapsed">
                                <Border x:Name="SystemCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="SystemCardTranslate" Y="12"/>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock x:Name="SystemHeader" Text="SYSTEM" Style="{StaticResource SectionHeader}"/>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="AutoStartCheck" x:Uid="autoStart" Content="Start with Windows"/>
                                                <TextBlock x:Name="AutoStartHint" Text="Launch automatically when you sign in."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="HelloGreetingCheck" x:Uid="helloGreeting" Content="Hello greeting on startup"/>
                                                <TextBlock x:Name="HelloGreetingHint" Text="Show handwriting 'hello' animation when the app starts."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="HideOnExclusiveFullscreenCheck" x:Uid="hideExclusiveFs" Content="Hide on exclusive fullscreen"/>
                                                <TextBlock x:Name="HideOnExclusiveFullscreenHint" Text="Hide the notch when a true fullscreen app is detected."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="HideOnWindowedFullscreenCheck" x:Uid="hideWindowedFs" Content="Hide on windowed fullscreen"/>
                                                <TextBlock x:Name="HideOnWindowedFullscreenHint" Text="Hide the notch when a borderless windowed fullscreen app is detected."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="MusicNotifyCheck" x:Uid="musicNotify" Content="Show music notifications"/>
                                                <TextBlock x:Name="MusicNotifyHint" Text="Keep the media widget responsive to playback changes."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <CheckBox x:Name="SystemNotifyCheck" x:Uid="systemNotify" Content="Show system notifications"/>
                                                <TextBlock x:Name="SystemNotifyHint" Text="Allow the notch to surface device and system signals."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <CheckBox x:Name="ShowBatteryCheck" x:Uid="showBattery" Content="Show battery indicator"/>
                                                <TextBlock x:Name="ShowBatteryHint" Text="Display battery level in the expanded notch."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <CheckBox x:Name="ShelfUnlockCheck" x:Uid="shelfUnlock" Content="Unlock shelf upload limit"/>
                                                <TextBlock x:Name="ShelfUnlockHint" Text="Remove the 30-file safety limit on the shelf."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <CheckBox x:Name="CopyShelfClipboardCheck" x:Uid="copyShelfClipboard" Content="Copy shelf files to clipboard"/>
                                                <TextBlock x:Name="CopyShelfClipboardHint" Text="When files are added to the shelf, automatically copy all of them to the system clipboard so you can paste them into other apps."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <TextBlock x:Name="LanguageLabel" Text="Language" Style="{StaticResource SettingTitleText}"/>
                                                <TextBlock x:Name="LanguageHint" Text="Choose the display language for V-Notch."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,6,0,8"/>
                                                <ComboBox x:Name="LanguageCombo" SelectionChanged="LanguageCombo_SelectionChanged"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ===== ADVANCED PANEL ===== -->
                            <StackPanel x:Name="PanelAdvanced" Visibility="Collapsed">
                                <Border x:Name="AdvancedCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="AdvancedCardTranslate" Y="12"/>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock x:Name="AdvancedHeader" Text="ADVANCED" Style="{StaticResource SectionHeader}"/>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="EnableSpotifyLyricsCheck"
                                                          x:Uid="enableSpotifyLyrics"
                                                          Content="Show Spotify lyrics"
                                                          Checked="EnableSpotifyLyricsCheck_Changed"
                                                          Unchecked="EnableSpotifyLyricsCheck_Changed"/>
                                                <TextBlock x:Name="EnableSpotifyLyricsHint"
                                                           Text="Display synced lyrics inside the expanded notch when listening on Spotify."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>

                                                <TextBlock x:Name="DarkOverlayLabel" Text="Lyrics Dark Overlay" Style="{StaticResource SettingTitleText}" Visibility="Collapsed" Margin="0,12,0,0"/>
                                                <TextBlock Grid.Column="1" Style="{StaticResource ValueText}" Visibility="Collapsed">
                                                    <Run x:Name="BlurDarkOverlayValue" Text="30"/><Run Text=" %"/>
                                                </TextBlock>
                                                <TextBlock x:Name="DarkOverlayHint" Visibility="Collapsed"/>
                                                <controls:ElasticSlider x:Name="BlurDarkOverlaySlider"
                                                        Label="Dark Overlay" Unit="%"
                                                        Description="Add a dark layer over the lyrics background image to improve text readability."
                                                        Minimum="0"
                                                        Maximum="80"
                                                        Value="30"
                                                        TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="BlurDarkOverlaySlider_ValueChanged"
                                                        Margin="0,12,0,0"/>

                                                <CheckBox x:Name="EnableYouTubeSubtitlesCheck"
                                                          x:Uid="enableYouTubeSubtitles"
                                                          Checked="EnableYouTubeSubtitlesCheck_Changed"
                                                          Unchecked="EnableYouTubeSubtitlesCheck_Changed"
                                                          Margin="0,14,0,0">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock x:Name="EnableYouTubeSubtitlesLabel" Text="Show YouTube subtitles" VerticalAlignment="Center"/>
                                                        <Border Background="#C8C8C8" CornerRadius="4" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center">
                                                            <TextBlock Text="ALPHA" FontSize="11" FontWeight="Bold"
                                                                       Foreground="#1A1A1A" FontFamily="{StaticResource SFProDisplay}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </CheckBox>
                                                <TextBlock x:Name="EnableYouTubeSubtitlesHint"
                                                           Text="Display synced closed captions inside the expanded notch when watching on YouTube."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Subtitle Language Priority -->
                                        <Border x:Name="SubtitlePriorityRow" Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock x:Name="SubtitlePriorityLabel" Text="Subtitle Language" Style="{StaticResource SettingTitleText}"/>
                                                </StackPanel>
                                                <TextBlock x:Name="SubtitlePriorityHint"
                                                           Text="Drag to reorder priority. Subtitles are selected using the first available match."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,6,0,8"/>
                                                <ItemsControl x:Name="SubtitlePriorityItems"
                                                              Background="Transparent"
                                                              AllowDrop="True"
                                                              Drop="SubtitlePriority_Drop"
                                                              DragOver="SubtitlePriority_DragOver">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Background="#1A1A1A" CornerRadius="8" Padding="12,10" Margin="0,2"
                                                                    Cursor="Hand"
                                                                    MouseMove="SubtitlePriorityItem_MouseMove"
                                                                    MouseLeftButtonDown="SubtitlePriorityItem_MouseLeftButtonDown"
                                                                    GiveFeedback="SubtitlePriorityItem_GiveFeedback">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="20"/>
                                                                        <ColumnDefinition Width="*"/>
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Text="≡" FontSize="14" Foreground="#555"
                                                                               VerticalAlignment="Center"/>
                                                                    <TextBlock Grid.Column="1" Text="{Binding DisplayName}"
                                                                               FontSize="13" Foreground="#E0E0E0"
                                                                               FontFamily="{StaticResource SFProDisplay}"
                                                                               FontWeight="Bold"
                                                                               VerticalAlignment="Center"/>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <CheckBox x:Name="YouTubeApiCheck" x:Uid="youtubeApi" Content="Use YouTube Data API"
                                                          Checked="YouTubeApiCheck_Changed" Unchecked="YouTubeApiCheck_Changed"/>
                                                <TextBlock x:Name="YouTubeApiHint" Text="Improve thumbnail accuracy with your own YouTube API key."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="YouTubeApiKeyRow" Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4" Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock x:Name="YouTubeApiKeyLabel" Text="API Key" Style="{StaticResource SettingTitleText}"/>
                                                <TextBlock x:Name="YouTubeApiKeyHint" Text="Paste your YouTube Data API v3 key from Google Cloud Console."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,6,0,8"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="40"/>
                                                    </Grid.ColumnDefinitions>
                                                    <PasswordBox x:Name="YouTubeApiKeyPasswordBox"
                                                             Height="40"
                                                             Padding="12,10"
                                                             FontSize="12"
                                                             FontFamily="{StaticResource SettingsFont}"
                                                             Background="#0F0F0F"
                                                             Foreground="#E0E0E0"
                                                             BorderBrush="#2A2A2A"
                                                             BorderThickness="1"
                                                             CaretBrush="#FFFFFF"
                                                             VerticalContentAlignment="Center"
                                                             PasswordChar="●"
                                                             PasswordChanged="YouTubeApiKeyPasswordBox_PasswordChanged">
                                                        <PasswordBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10"/>
                                                            </Style>
                                                        </PasswordBox.Resources>
                                                    </PasswordBox>
                                                    <TextBox x:Name="YouTubeApiKeyTextBox"
                                                             Height="40"
                                                             Padding="12,10"
                                                             FontSize="12"
                                                             FontFamily="{StaticResource SettingsFont}"
                                                             Background="#0F0F0F"
                                                             Foreground="#E0E0E0"
                                                             BorderBrush="#2A2A2A"
                                                             BorderThickness="1"
                                                             CaretBrush="#FFFFFF"
                                                             VerticalContentAlignment="Center"
                                                             Visibility="Collapsed"
                                                             TextChanged="YouTubeApiKeyTextBox_TextChanged">
                                                        <TextBox.Resources>
                                                            <Style TargetType="Border">
                                                                <Setter Property="CornerRadius" Value="10"/>
                                                            </Style>
                                                        </TextBox.Resources>
                                                    </TextBox>
                                                    <Button x:Name="ToggleKeyVisibilityButton"
                                                            Grid.Column="1"
                                                            Width="36" Height="36"
                                                            Background="Transparent"
                                                            BorderThickness="0"
                                                            Cursor="Hand"
                                                            VerticalAlignment="Center"
                                                            HorizontalAlignment="Center"
                                                            Click="ToggleKeyVisibility_Click"
                                                            ToolTip="Show/Hide key">
                                                        <Grid Width="20" Height="20">
                                                            <Canvas x:Name="EyeOpenIcon" Width="20" Height="20" Opacity="1">
                                                                <Path Fill="#CCCCCC" Data="M10 4C5.6 4 1.9 6.7 0.2 10.5C0.1 10.8 0.1 11.2 0.2 11.5C1.9 15.3 5.6 18 10 18C14.4 18 18.1 15.3 19.8 11.5C19.9 11.2 19.9 10.8 19.8 10.5C18.1 6.7 14.4 4 10 4ZM10 15.5C7.5 15.5 5.5 13.5 5.5 11C5.5 8.5 7.5 6.5 10 6.5C12.5 6.5 14.5 8.5 14.5 11C14.5 13.5 12.5 15.5 10 15.5ZM10 8.5C8.6 8.5 7.5 9.6 7.5 11C7.5 12.4 8.6 13.5 10 13.5C11.4 13.5 12.5 12.4 12.5 11C12.5 9.6 11.4 8.5 10 8.5Z"/>
                                                            </Canvas>
                                                            <Canvas x:Name="EyeClosedIcon" Width="20" Height="20" Opacity="0">
                                                                <Path Data="M2.5 2.5L17.5 17.5M8.1 8.2C7.7 8.6 7.5 9.3 7.5 10C7.5 11.4 8.6 12.5 10 12.5C10.7 12.5 11.4 12.3 11.8 11.8M14.1 14.2C12.9 15.1 11.5 15.5 10 15.5C5.6 15.5 1.9 12.8 0.2 9C0.9 7.5 1.9 6.2 3.2 5.2M7.5 4.5C8.3 4.2 9.1 4 10 4C14.4 4 18.1 6.7 19.8 10.5C19.4 11.4 18.9 12.2 18.3 12.9" Stroke="#CCCCCC" StrokeThickness="1.5" Fill="Transparent"/>
                                                            </Canvas>
                                                        </Grid>
                                                    </Button>
                                                </Grid>
                                                <TextBlock x:Name="YouTubeApiKeyStatus" 
                                                           Text=""
                                                           FontSize="11"
                                                           Foreground="#6B7280"
                                                           Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ===== PERFORMANCE PANEL ===== -->
                            <StackPanel x:Name="PanelPerformance" Visibility="Collapsed">
                                <Border x:Name="PerformanceCard" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="PerformanceCardTranslate" Y="12"/>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock x:Name="PerformanceHeader" Text="PERFORMANCE" Style="{StaticResource SectionHeader}"/>

                                        <Border Style="{StaticResource SettingRowBorder}">
                                            <StackPanel>
                                                <TextBlock x:Name="AnimationFpsLabel" Text="Animation FPS" Style="{StaticResource SettingTitleText}" Visibility="Collapsed"/>
                                                <TextBlock Grid.Column="1" Style="{StaticResource ValueText}" Visibility="Collapsed">
                                                    <Run x:Name="AnimationFpsValue" Text="144"/><Run Text=" FPS"/>
                                                </TextBlock>
                                                <TextBlock x:Name="AnimationFpsHint" Visibility="Collapsed"/>
                                                <controls:ElasticSlider x:Name="AnimationFpsSlider"
                                                        Label="Animation FPS" Unit=" FPS"
                                                        Description="Cap UI animation frame rate. Lower values reduce render/GPU load."
                                                        Minimum="60"
                                                        Maximum="144"
                                                        Value="144"
                                                        TickFrequency="12"
                                                        IsSnapToTickEnabled="False"
                                                        ValueChanged="AnimationFpsSlider_ValueChanged"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,4,0,4">
                                            <StackPanel>
                                                <CheckBox x:Name="EnableBlurEffectsCheck"
                                                          Content="Enable blur effects"
                                                          Checked="PerformanceSetting_Changed"
                                                          Unchecked="PerformanceSetting_Changed"/>
                                                <TextBlock x:Name="EnableBlurEffectsHint"
                                                           Text="Use media background blur, content transition blur, and other visual blur effects."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="SubjectBlurRow" Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <CheckBox x:Name="EnableSubjectBlurCheck"
                                                          Content="Subject-aware media blur"
                                                          Checked="PerformanceSetting_Changed"
                                                          Unchecked="PerformanceSetting_Changed"/>
                                                <TextBlock x:Name="EnableSubjectBlurHint"
                                                           Text="Keeps media subjects clearer inside the blurred background. Disable it for a cheaper blur pass."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                            <StackPanel>
                                                <CheckBox x:Name="EnableSmartCropCheck"
                                                          Content="Smart thumbnail crop"
                                                          Checked="PerformanceSetting_Changed"
                                                          Unchecked="PerformanceSetting_Changed"/>
                                                <TextBlock x:Name="EnableSmartCropHint"
                                                           Text="Use the ONNX model to find better thumbnail crops. Disable it to avoid the heavier image-analysis path."
                                                           Style="{StaticResource SettingHintText}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ===== DONATING PANEL ===== -->
                            <StackPanel x:Name="PanelDonating" Visibility="Collapsed">
                                <Border x:Name="DonatingCard" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="DonatingCardTranslate" Y="12"/>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock x:Name="DonatingHeader" Text="DONATING" Style="{StaticResource SectionHeader}"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="196"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0" Margin="0,0,22,0">
                                                <TextBlock x:Name="DonatingTitle"
                                                           Text="Thank you for supporting V-Notch"
                                                           Style="{StaticResource SettingTitleText}"
                                                           FontSize="16"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock x:Name="DonatingDescription"
                                                           Text="V-Notch is 100% non-profit. Donations help cover the costs that let me stay focused and keep maintaining this product."
                                                           Style="{StaticResource SettingHintText}"
                                                           FontSize="12.5"
                                                           LineHeight="18"
                                                           Margin="0,8,0,0"/>

                                                <Button x:Name="DonatePaypalButton"
                                                        Content="Support via PayPal"
                                                        Style="{StaticResource PrimaryButton}"
                                                        Click="DonatePaypal_Click"
                                                        HorizontalAlignment="Left"
                                                        MinWidth="174"
                                                        Height="40"
                                                        Margin="0,18,0,0"/>

                                                <TextBlock x:Name="DonatePaypalLinkText"
                                                           Text="https://www.paypal.com/paypalme/PhuocLe678"
                                                           Style="{StaticResource SettingHintText}"
                                                           Foreground="#A8B3C3"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock x:Name="DonatingBankTitle"
                                                           Text="Domestic MB Bank QR"
                                                           Style="{StaticResource SettingTitleText}"
                                                           TextAlignment="Center"
                                                           HorizontalAlignment="Center"/>
                                                <Border Width="176"
                                                        Height="176"
                                                        Background="White"
                                                        CornerRadius="12"
                                                        Padding="8"
                                                        Margin="0,10,0,0">
                                                    <Image Source="pack://application:,,,/Assets/QR.PNG"
                                                           Stretch="Uniform"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                </Border>
                                                <TextBlock x:Name="DonatingBankHint"
                                                           Text="Scan this QR for domestic bank support."
                                                           Style="{StaticResource SettingHintText}"
                                                           Width="176"
                                                           TextAlignment="Center"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ===== UPDATES PANEL ===== -->
                            <StackPanel x:Name="PanelUpdates" Visibility="Collapsed">
                                <Border x:Name="UpdatesCard" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6" Opacity="0">
                                    <Border.RenderTransform>
                                        <TranslateTransform x:Name="UpdatesCardTranslate" Y="12"/>
                                    </Border.RenderTransform>
                                    <StackPanel>
                                        <TextBlock x:Name="UpdatesHeader" Text="UPDATES &amp; REPORT BUG" Style="{StaticResource SectionHeader}"/>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock x:Name="UpdateStatusText"
                                                               Text="Checking for updates..."
                                                               Style="{StaticResource SettingTitleText}"
                                                               TextWrapping="Wrap"/>
                                                    <TextBlock x:Name="CurrentVersionText"
                                                               Text="Current version: 1.6.1"
                                                               Style="{StaticResource SettingHintText}"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>

                                                <Button x:Name="CheckUpdateButton"
                                                        Grid.Column="1"
                                                        Content="Check"
                                                        MinWidth="92"
                                                        Height="40"
                                                        Click="CheckUpdate_Click"/>
                                            </Grid>
                                        </Border>

                                        <Button x:Name="DownloadUpdateButton"
                                                Content="Download &amp; Install Update"
                                                Visibility="Collapsed"
                                                Click="DownloadUpdate_Click"
                                                Style="{StaticResource PrimaryButton}"
                                                Margin="0,4,0,0"/>

                                        <Border Style="{StaticResource SettingRowBorder}" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Margin="0,0,12,0">
                                                    <TextBlock x:Name="ReportBugLabel" Text="Report a bug"
                                                               Style="{StaticResource SettingTitleText}"/>
                                                    <TextBlock x:Name="ReportBugHint" Text="Found something broken? Let us know on GitHub."
                                                               Style="{StaticResource SettingHintText}"
                                                               Margin="0,6,0,0"/>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Width="40"
                                                        Height="40"
                                                        Click="ReportBug_Click"
                                                        ToolTip="Report Bug on GitHub"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Viewbox Width="36" Height="36" Stretch="Uniform">
