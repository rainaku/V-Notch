                        <StackPanel>
                            <TextBlock x:Name="AppearanceHeader" Text="APPEARANCE" Style="{StaticResource SectionHeader}"/>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <TextBlock x:Name="WidthLabel" Text="Width" Style="{StaticResource SettingTitleText}" Visibility="Collapsed"/>
