                                                        Description="Sharper for utility, softer for an island-like feel."
                                                        Minimum="0"
                                                        Maximum="30"
                                                        Value="16"
                                                        TickFrequency="2"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="RadiusSlider_ValueChanged"/>


                                            </StackPanel>
