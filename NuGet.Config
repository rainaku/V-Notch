<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Keep restores reproducible and avoid the obsolete NuGet v2 endpoint
         configured in some user-level NuGet.Config files. -->
    <clear />
    <!-- Use a distinct key because some machines have a disabled user-level
         source named "nuget.org"; disabled source names are inherited. -->
    <add key="nuget-v3" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>