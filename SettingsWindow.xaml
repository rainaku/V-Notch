<Window x:Class="VNotch.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="V-Notch Settings"
        Width="860"
        Height="620"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Loaded="Window_Loaded">

    <Window.Resources>
        <FontFamily x:Key="SettingsFont">Aptos, Segoe UI Variable Display, Segoe UI Variable Text, Segoe UI, Inter, Sans-serif</FontFamily>
        <SolidColorBrush x:Key="PanelBg" Color="#F4020202"/>
        <SolidColorBrush x:Key="CardBg" Color="#F0080808"/>
        <SolidColorBrush x:Key="CardBorder" Color="#14FFFFFF"/>
        <SolidColorBrush x:Key="MutedText" Color="#8C959E"/>
        <SolidColorBrush x:Key="SoftText" Color="#D8DEE5"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#F2F2F2"/>
        <SolidColorBrush x:Key="AccentBrushStrong" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TrackBg" Color="#262626"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#141414"/>
        <SolidColorBrush x:Key="SurfaceBrushHover" Color="#1B1B1B"/>

        <LinearGradientBrush x:Key="WindowGlow" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#090909" Offset="0"/>
            <GradientStop Color="#030303" Offset="0.55"/>
            <GradientStop Color="#000000" Offset="1"/>
        </LinearGradientBrush>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#7C7C7C"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>

        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBg}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="18"/>
            <Setter Property="Padding" Value="18"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TransformGroup>
                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                        <TranslateTransform Y="0"/>
                    </TransformGroup>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#20FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SettingTitleText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="SettingHintText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedText}"/>
            <Setter Property="FontSize" Value="11.5"/>
            <Setter Property="FontWeight" Value="Medium"/>
        </Style>

        <Style x:Key="ValueText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4F4F4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style x:Key="SliderLabelGrid" TargetType="Grid">
            <Setter Property="Margin" Value="0,0,0,2"/>
        </Style>

        <Style x:Key="SettingRowBorder" TargetType="Border">
            <Setter Property="Background" Value="#0AFFFFFF"/>
            <Setter Property="BorderBrush" Value="#10FFFFFF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid MinHeight="26" SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="52"/>
                            </Grid.ColumnDefinitions>

                            <ContentPresenter Grid.Column="0"
                                              VerticalAlignment="Center"
                                              Margin="0,3,12,3"
                                              RecognizesAccessKey="True"/>

                            <Border x:Name="SwitchTrack"
                                    Grid.Column="1"
                                    Width="42"
                                    Height="24"
                                    CornerRadius="12"
                                    Background="#161616"
                                    BorderBrush="#4A4A4A"
                                    BorderThickness="1"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">
                                <Grid>
                                    <Ellipse x:Name="SwitchThumb"
                                             Width="18"
                                             Height="18"
                                             Fill="#F3F7FB"
                                             Margin="3,0,0,0"
                                             HorizontalAlignment="Left"
                                             VerticalAlignment="Center">
                                        <Ellipse.Effect>
                                            <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.22"/>
                                        </Ellipse.Effect>
                                    </Ellipse>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#1E1E1E"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#7A7A7A"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="#F3F7FB"/>
                                <Setter TargetName="SwitchTrack" Property="BorderBrush" Value="#F3F7FB"/>
                                <Setter TargetName="SwitchThumb" Property="Fill" Value="#0C0C0C"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="21,0,0,0"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="21,0,0,0"
                                                                Duration="0:0:0.22"
                                                                Timeline.DesiredFrameRate="144">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#F3F7FB"
                                                            Duration="0:0:0.2"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#F3F7FB"
                                                            Duration="0:0:0.2"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchThumb"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="#0C0C0C"
                                                            Duration="0:0:0.18"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ThicknessAnimation Storyboard.TargetName="SwitchThumb"
                                                                Storyboard.TargetProperty="Margin"
                                                                To="3,0,0,0"
                                                                Duration="0:0:0.22"
                                                                Timeline.DesiredFrameRate="144">
                                                <ThicknessAnimation.EasingFunction>
                                                    <CubicEase EasingMode="EaseOut"/>
                                                </ThicknessAnimation.EasingFunction>
                                            </ThicknessAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                            To="#161616"
                                                            Duration="0:0:0.2"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchTrack"
                                                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                            To="#4A4A4A"
                                                            Duration="0:0:0.2"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                            <ColorAnimation Storyboard.TargetName="SwitchThumb"
                                                            Storyboard.TargetProperty="(Shape.Fill).(SolidColorBrush.Color)"
                                                            To="#F3F7FB"
                                                            Duration="0:0:0.18"
                                                            Timeline.DesiredFrameRate="144">
                                                <ColorAnimation.EasingFunction>
                                                    <QuadraticEase EasingMode="EaseOut"/>
                                                </ColorAnimation.EasingFunction>
                                            </ColorAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Slider">
            <Setter Property="Margin" Value="0,6,0,14"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="30" SnapsToDevicePixels="True">
                            <Track x:Name="PART_Track" VerticalAlignment="Center" Height="30">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" CornerRadius="3" Background="{StaticResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="6" CornerRadius="3" Background="{StaticResource TrackBg}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="22" Height="22">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Grid RenderTransformOrigin="0.5,0.5">
                                                    <Grid.RenderTransform>
                                                        <ScaleTransform ScaleX="1" ScaleY="1"/>
                                                    </Grid.RenderTransform>
                                                    <Ellipse Fill="#0B000000" Margin="1,2,1,0" Opacity="0.34"/>
                                                    <Ellipse x:Name="ThumbFace" Fill="#F7FAFD" Stroke="#E2EAF3" StrokeThickness="1"/>
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ThumbFace" Property="Fill" Value="White"/>
                                                    </Trigger>
                                                    <Trigger Property="IsDragging" Value="True">
                                                        <Setter Property="RenderTransform">
                                                            <Setter.Value>
                                                                <ScaleTransform ScaleX="1.12" ScaleY="1.12"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F5F8FB"/>
            <Setter Property="Background" Value="#1B2129"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Margin" Value="0,8,0,0"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="#F5F8FB"/>
            <Setter Property="BorderBrush" Value="#304051"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="ComboBorder"
                                                Background="{StaticResource SurfaceBrush}"
                                                BorderBrush="#2A2A2A"
                                                BorderThickness="1"
                                                CornerRadius="12"
                                                Padding="14,0">
                                                <Grid>
                                                    <ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Left"
                                                                  TextElement.Foreground="#F5F8FB"/>
                                                <Path Data="M 0 0 L 4 4 L 8 0"
                                                      Stroke="#C8D1DD"
                                                      StrokeThickness="1.6"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <EventTrigger RoutedEvent="MouseEnter">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ComboBorder"
                                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="1.012"
                                                                         Duration="0:0:0.16"
                                                                         Timeline.DesiredFrameRate="144">
                                                            <DoubleAnimation.EasingFunction>
                                                                <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="ComboBorder"
                                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                         To="1.012"
                                                                         Duration="0:0:0.16"
                                                                         Timeline.DesiredFrameRate="144">
                                                            <DoubleAnimation.EasingFunction>
                                                                <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <EventTrigger RoutedEvent="MouseLeave">
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="ComboBorder"
                                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                                         To="1"
                                                                         Duration="0:0:0.22"
                                                                         Timeline.DesiredFrameRate="144">
                                                            <DoubleAnimation.EasingFunction>
                                                                <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                        <DoubleAnimation Storyboard.TargetName="ComboBorder"
                                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                                         To="1"
                                                                         Duration="0:0:0.22"
                                                                         Timeline.DesiredFrameRate="144">
                                                            <DoubleAnimation.EasingFunction>
                                                                <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                                            </DoubleAnimation.EasingFunction>
                                                        </DoubleAnimation>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="#4C4C4C"/>
                                                <Setter TargetName="ComboBorder" Property="Background" Value="{StaticResource SurfaceBrushHover}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False">
                                <Border Background="#101010"
                                        BorderBrush="#2A2A2A"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="180">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent" Margin="0,8,4,8">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton><RepeatButton Command="ScrollBar.LineUpCommand" Opacity="0"/></Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton><RepeatButton Command="ScrollBar.LineDownCommand" Opacity="0"/></Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#505050" CornerRadius="4" Margin="2,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
            <Setter Property="Foreground" Value="#F7FAFD"/>
            <Setter Property="BorderBrush" Value="#2B2B2B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontFamily" Value="{StaticResource SettingsFont}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         To="1.02"
                                                         Duration="0:0:0.16"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         To="1.02"
                                                         Duration="0:0:0.16"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="-1"
                                                         Duration="0:0:0.16"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.24"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.24"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="0"
                                                         Duration="0:0:0.24"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{StaticResource SurfaceBrushHover}"/>
                                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#484848"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#202020"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.988" ScaleY="0.988"/>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#F3F6FA"/>
            <Setter Property="Foreground" Value="#11161D"/>
            <Setter Property="BorderBrush" Value="#F3F6FA"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <TransformGroup>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                    <TranslateTransform Y="0"/>
                                </TransformGroup>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         To="1.024"
                                                         Duration="0:0:0.16"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         To="1.024"
                                                         Duration="0:0:0.16"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="5"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="-1"
                                                         Duration="0:0:0.16"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleX)"
                                                         To="1"
                                                         Duration="0:0:0.24"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[0].(ScaleTransform.ScaleY)"
                                                         To="1"
                                                         Duration="0:0:0.24"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <ExponentialEase EasingMode="EaseOut" Exponent="4"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                        <DoubleAnimation Storyboard.TargetName="ButtonBorder"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(TransformGroup.Children)[1].(TranslateTransform.Y)"
                                                         To="0"
                                                         Duration="0:0:0.24"
                                                         Timeline.DesiredFrameRate="144">
                                            <DoubleAnimation.EasingFunction>
                                                <CubicEase EasingMode="EaseOut"/>
                                            </DoubleAnimation.EasingFunction>
                                        </DoubleAnimation>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#DDE5EF"/>
                                <Setter TargetName="ButtonBorder" Property="RenderTransform">
                                    <Setter.Value>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="0.988" ScaleY="0.988"/>
                                            <TranslateTransform Y="0"/>
                                        </TransformGroup>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="MainShell"
            Margin="18"
            CornerRadius="24"
            Background="{StaticResource WindowGlow}"
            BorderBrush="#18FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True"
            Opacity="0"
            PreviewMouseLeftButtonDown="WindowSurface_PreviewMouseLeftButtonDown"
            RenderTransformOrigin="0.5,0.5">
        <Border.RenderTransform>
            <TransformGroup>
                <ScaleTransform x:Name="ShellScale" ScaleX="0.985" ScaleY="0.985"/>
                <TranslateTransform x:Name="ShellTranslate" Y="8"/>
            </TransformGroup>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.42"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border x:Name="SettingsHeader"
                    Grid.Row="0"
                    Padding="22,20,18,18"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="HeaderTranslate" Y="10"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="56"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Notch Settings"
                                       FontSize="19"
                                       FontWeight="Bold"
                                       Foreground="#F8FBFF"/>
                            <TextBlock Text="Tune behavior, visuals, and system integration."
                                       Style="{StaticResource SettingHintText}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Width="42"
                            Height="42"
                            MinWidth="0"
                            BorderThickness="0"
                            Background="#121212"
                            Foreground="#F3F7FB"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="11"
                            Content="&#xE711;"
                            Click="Cancel_Click"/>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="20,18,14,14">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                    <Border x:Name="AppearanceCard" Style="{StaticResource CardBorderStyle}" Padding="18,16,18,10" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="AppearanceCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeader}"/>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SliderLabelGrid}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Width" Style="{StaticResource SettingTitleText}"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource ValueText}">
                                            <Run x:Name="WidthValue" Text="360"/><Run Text=" px"/>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="How wide the compact notch should sit on screen."
                                               Style="{StaticResource SettingHintText}"/>
                                    <Slider x:Name="WidthSlider"
                                            Minimum="100"
                                            Maximum="400"
                                            Value="200"
                                            TickFrequency="10"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="WidthSlider_ValueChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SliderLabelGrid}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Height" Style="{StaticResource SettingTitleText}"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource ValueText}">
                                            <Run x:Name="HeightValue" Text="32"/><Run Text=" px"/>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="Controls the compact profile thickness."
                                               Style="{StaticResource SettingHintText}"/>
                                    <Slider x:Name="HeightSlider"
                                            Minimum="20"
                                            Maximum="50"
                                            Value="32"
                                            TickFrequency="2"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="HeightSlider_ValueChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <Grid Style="{StaticResource SliderLabelGrid}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Corner Radius" Style="{StaticResource SettingTitleText}"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource ValueText}">
                                            <Run x:Name="RadiusValue" Text="16"/><Run Text=" px"/>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="Sharper for utility, softer for an island-like feel."
                                               Style="{StaticResource SettingHintText}"/>
                                    <Slider x:Name="RadiusSlider"
                                            Minimum="0"
                                            Maximum="30"
                                            Value="16"
                                            TickFrequency="2"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="RadiusSlider_ValueChanged"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <Grid Style="{StaticResource SliderLabelGrid}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Opacity" Style="{StaticResource SettingTitleText}"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource ValueText}">
                                            <Run x:Name="OpacityValue" Text="100"/><Run Text=" %"/>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="Blend the notch into the desktop or keep it crisp and solid."
                                               Style="{StaticResource SettingHintText}"/>
                                    <Slider x:Name="OpacitySlider"
                                            Minimum="50"
                                            Maximum="100"
                                            Value="100"
                                            TickFrequency="5"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="OpacitySlider_ValueChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="BehaviorCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="BehaviorCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionHeader}"/>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="HoverExpandCheck" Content="Expand on hover"/>
                                    <TextBlock Text="Open the notch automatically when the pointer lingers nearby."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <Grid Style="{StaticResource SliderLabelGrid}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Expand Delay" Style="{StaticResource SettingTitleText}"/>
                                        <TextBlock Grid.Column="1" Style="{StaticResource ValueText}">
                                            <Run x:Name="HoverDelayValue" Text="100"/><Run Text=" ms"/>
                                        </TextBlock>
                                    </Grid>
                                    <TextBlock Text="Delay before hover opens the notch."
                                               Style="{StaticResource SettingHintText}"/>
                                    <Slider x:Name="HoverDelaySlider"
                                            Minimum="0"
                                            Maximum="500"
                                            Value="100"
                                            TickFrequency="50"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="HoverDelaySlider_ValueChanged"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="UpdatesCard" Style="{StaticResource CardBorderStyle}" Margin="0,0,0,6" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="UpdatesCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="UPDATES" Style="{StaticResource SectionHeader}"/>

                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,12,0">
                                        <TextBlock x:Name="UpdateStatusText"
                                                   Text="Checking for updates..."
                                                   Style="{StaticResource SettingTitleText}"/>
                                        <TextBlock x:Name="CurrentVersionText"
                                                   Text="Current version: 1.6.0"
                                                   Style="{StaticResource SettingHintText}"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <Button x:Name="CheckUpdateButton"
                                            Grid.Column="1"
                                            Content="Check"
                                            Width="92"
                                            Height="40"
                                            Click="CheckUpdate_Click"/>
                                </Grid>
                            </Border>

                            <Button x:Name="DownloadUpdateButton"
                                    Content="Download &amp; Install Update"
                                    Visibility="Collapsed"
                                    Click="DownloadUpdate_Click"
                                    Style="{StaticResource PrimaryButton}"/>
                        </StackPanel>
                    </Border>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                    <Border x:Name="DisplayCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="DisplayCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeader}"/>
                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <TextBlock Text="Active Monitor" Style="{StaticResource SettingTitleText}"/>
                                    <TextBlock Text="Choose which screen anchors the notch."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,6,0,0"/>
                                    <ComboBox x:Name="MonitorCombo"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SystemCard" Style="{StaticResource CardBorderStyle}" Opacity="0">
                        <Border.RenderTransform>
                            <TranslateTransform x:Name="SystemCardTranslate" Y="12"/>
                        </Border.RenderTransform>
                        <StackPanel>
                            <TextBlock Text="SYSTEM" Style="{StaticResource SectionHeader}"/>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="AutoStartCheck" Content="Start with Windows"/>
                                    <TextBlock Text="Launch automatically when you sign in."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}">
                                <StackPanel>
                                    <CheckBox x:Name="MusicNotifyCheck" Content="Show music notifications"/>
                                    <TextBlock Text="Keep the media widget responsive to playback changes."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource SettingRowBorder}" Margin="0,0,0,4">
                                <StackPanel>
                                    <CheckBox x:Name="SystemNotifyCheck" Content="Show system notifications"/>
                                    <TextBlock Text="Allow the notch to surface device and system signals."
                                               Style="{StaticResource SettingHintText}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border x:Name="FooterBar"
                    Grid.Row="2"
                    Background="#D1050505"
                    BorderBrush="#10FFFFFF"
                    BorderThickness="0,1,0,0"
                    Padding="18"
                    Opacity="0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="FooterTranslate" Y="10"/>
                </Border.RenderTransform>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0"
                            Margin="0,0,8,0"
                            Content="Reset"
                            Click="Reset_Click"/>
                    <Button Grid.Column="1"
                            Margin="4,0"
                            Content="Apply"
                            Click="Apply_Click"/>
                    <Button Grid.Column="2"
                            Margin="8,0,0,0"
                            Content="Save"
                            Style="{StaticResource PrimaryButton}"
                            Click="Save_Click"/>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
